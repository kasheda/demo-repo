DAY44_BACKEND_PORT=3000
DAY44_FRONTEND_PORT=8044

DAY44_APP_ENV=day44-dev-env
DAY44_DEPLOY_TARGET=dev
DAY44_APP_VERSION=day44-dev-v1
DAY44_SERVICE_NAME=day44-backend
DAY44_FEATURE_FLAG=enabled
DAY44_LOG_LEVEL=info
DAY44_METRICS_ENABLED=true
DAY44_BUILD_NUMBER=local
DAY44_GIT_COMMIT=local
DAY44_IMAGE_TAG=day44-local
DAY44_RELEASE_CREATED_AT=local
DAY44_ROLLBACK_IMAGE_TAG=day44-local
DAY44_ROLLBACK_MODE=normal
DAY44_STABILITY_CHECK_WINDOW_SECONDS=15
DAY44_STABILITY_CHECK_INTERVAL_SECONDS=5
DAY44_FORCE_STABILITY_FAILURE=false
