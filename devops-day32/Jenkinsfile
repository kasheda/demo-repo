pipeline {
    agent any

    environment {
        DAY_NAME = 'Day 32'
        PROJECT_DIR = 'devops-day32'
        BACKEND_CONTAINER = 'day32_backend'
        FRONTEND_CONTAINER = 'day32_frontend'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code for Day 32...'
                checkout scm
            }
        }

        stage('Validate Day 32 Jenkins Runtime') {
            steps {
                sh '''
                set -e

                echo "Validating Day 32 Jenkins runtime tools..."

                git --version
                node --version
                npm --version
                docker --version
                docker compose version

                echo "Day 32 Jenkins runtime has required tools."
                '''
            }
        }

        stage('Validate Day 32 Project Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 32 required project files..."

                    REQUIRED_FILES="
backend/app.js
backend/package.json
backend/Dockerfile
backend/.dockerignore
frontend/index.html
frontend/nginx.conf
frontend/Dockerfile
frontend/.dockerignore
.env
docker-compose.yml
Jenkinsfile
README.md
"

                    for file in $REQUIRED_FILES; do
                      if [ ! -f "$file" ]; then
                        echo "Missing required Day 32 file: $file"
                        echo "Current Day 32 files:"
                        find . -maxdepth 3 -type f | sort
                        exit 1
                      fi

                      echo "Found Day 32 file: $file"
                    done

                    echo "All Day 32 required files found."
                    '''
                }
            }
        }

        stage('Validate Day 32 Backend Syntax') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Validating Day 32 backend JavaScript syntax..."
                    node --check app.js

                    echo "Day 32 backend syntax is valid."
                    '''
                }
            }
        }

        stage('Validate Day 32 Frontend Files') {
            steps {
                dir("${PROJECT_DIR}/frontend") {
                    sh '''
                    set -e

                    echo "Validating Day 32 frontend files..."

                    test -s index.html
                    test -s nginx.conf

                    grep "DevOps Day 32" index.html
                    grep "day32-backend" nginx.conf

                    echo "Day 32 frontend files are valid."
                    '''
                }
            }
        }

        stage('Validate Day 32 Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 32 .env file..."

                    REQUIRED_ENV_KEYS="
DAY32_BACKEND_PORT=3000
DAY32_FRONTEND_PORT=8080
DAY32_APP_ENV=day32-env-file
DAY32_APP_VERSION=day32-v1
DAY32_SERVICE_NAME=day32-backend
DAY32_FEATURE_FLAG=enabled
"

                    for key in $REQUIRED_ENV_KEYS; do
                      grep "$key" .env
                      echo "Found Day 32 env value: $key"
                    done

                    echo "Day 32 .env file validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 32 Compose Health Dependency') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 32 Docker Compose health dependency..."

                    grep "condition: service_healthy" docker-compose.yml
                    grep "healthcheck:" docker-compose.yml
                    grep "day32-backend:" docker-compose.yml

                    echo "Day 32 Compose health dependency validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 32 App Fails Without Required Env') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Testing that Day 32 backend fails fast without required environment variables..."

                    set +e
                    node app.js > day32-missing-env.log 2>&1
                    EXIT_CODE=$?
                    set -e

                    cat day32-missing-env.log

                    if [ "$EXIT_CODE" -eq 0 ]; then
                      echo "Day 32 backend unexpectedly started without required environment variables."
                      rm -f day32-missing-env.log
                      exit 1
                    fi

                    grep "Missing required environment variables" day32-missing-env.log

                    rm -f day32-missing-env.log

                    echo "Day 32 backend correctly fails when required environment variables are missing."
                    '''
                }
            }
        }

        stage('Render Day 32 Docker Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Rendering Day 32 Docker Compose config with .env values..."
                    docker compose config

                    echo "Day 32 Docker Compose config rendered successfully."
                    '''
                }
            }
        }

        stage('Build Day 32 Docker Images') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Building Day 32 Docker images without cache..."
                    docker compose build --no-cache

                    echo "Day 32 Docker images built successfully."
                    '''
                }
            }
        }

        stage('Deploy Day 32 With Docker Compose') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Stopping old Day 32 containers if they exist..."
                    docker compose down || true

                    echo "Starting Day 32 application..."
                    docker compose up -d

                    echo "Current Day 32 containers:"
                    docker ps --filter "name=day32_"
                    '''
                }
            }
        }

        stage('Verify Day 32 Frontend Waited for Backend Health') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Verifying Day 32 dependency behavior..."

                    BACKEND_HEALTH=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                    FRONTEND_RUNNING=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}' 2>/dev/null || echo "unknown")

                    echo "Day 32 backend health: $BACKEND_HEALTH"
                    echo "Day 32 frontend running: $FRONTEND_RUNNING"

                    if [ "$BACKEND_HEALTH" != "healthy" ]; then
                      echo "Day 32 backend is not healthy."
                      docker logs --tail=50 "$BACKEND_CONTAINER" || true
                      exit 1
                    fi

                    if [ "$FRONTEND_RUNNING" != "true" ]; then
                      echo "Day 32 frontend is not running."
                      docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                      exit 1
                    fi

                    echo "Day 32 frontend is running after backend became healthy."
                    '''
                }
            }
        }

        stage('Wait for Day 32 Docker Health') {
            steps {
                sh '''
                set -e

                echo "Waiting for Day 32 backend container health..."

                for i in $(seq 1 12); do
                  STATUS=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                  RUNNING=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Running}}' 2>/dev/null || echo "unknown")

                  echo "Attempt $i: Day 32 backend running = $RUNNING, health = $STATUS"

                  if [ "$STATUS" = "healthy" ]; then
                    echo "Day 32 backend container is healthy."
                    exit 0
                  fi

                  if [ "$RUNNING" = "false" ]; then
                    echo "Day 32 backend container stopped before becoming healthy."
                    docker logs --tail=50 "$BACKEND_CONTAINER" || true
                    exit 1
                  fi

                  if [ "$STATUS" = "unhealthy" ]; then
                    echo "Day 32 backend container is unhealthy."
                    docker logs --tail=50 "$BACKEND_CONTAINER" || true
                    exit 1
                  fi

                  sleep 5
                done

                echo "Day 32 backend did not become healthy in time."
                docker inspect "$BACKEND_CONTAINER" || true
                docker logs --tail=50 "$BACKEND_CONTAINER" || true
                exit 1
                '''
            }
        }

        stage('Smoke Test Day 32 Backend Health') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 32 backend health endpoint..."
                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1:3000/health")

                echo "Day 32 backend health response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"status":"ok"'
                echo "$RESPONSE" | grep '"service":"day32-backend"'
                echo "$RESPONSE" | grep '"environment":"day32-env-file"'
                echo "$RESPONSE" | grep '"version":"day32-v1"'

                echo "Day 32 backend health smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 32 Backend Ready') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 32 backend readiness endpoint..."
                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1:3000/ready")

                echo "Day 32 backend ready response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"ready":true'
                echo "$RESPONSE" | grep '"service":"day32-backend"'

                echo "Day 32 backend readiness smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 32 Backend API') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 32 backend API endpoint..."
                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1:3000/api/message")

                echo "Day 32 backend API response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep 'Hello from Day 32 backend API'
                echo "$RESPONSE" | grep '"service":"day32-backend"'
                echo "$RESPONSE" | grep '"environment":"day32-env-file"'
                echo "$RESPONSE" | grep '"featureFlag":"enabled"'

                echo "Day 32 backend API smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 32 Runtime Config') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 32 runtime config endpoint..."
                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1:3000/api/config")

                echo "Day 32 runtime config response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day32-backend"'
                echo "$RESPONSE" | grep '"environment":"day32-env-file"'
                echo "$RESPONSE" | grep '"version":"day32-v1"'
                echo "$RESPONSE" | grep '"featureFlag":"enabled"'
                echo "$RESPONSE" | grep '"port":3000'

                echo "Day 32 runtime config smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 32 Frontend Page') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 32 frontend page..."
                RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/")

                echo "Day 32 frontend page response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep 'DevOps Day 32'
                echo "$RESPONSE" | grep 'Frontend starts only after the Day 32 backend becomes healthy'

                echo "Day 32 frontend page smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 32 Frontend API Proxy') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 32 frontend-to-backend proxy..."
                RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/api/config")

                echo "Day 32 frontend proxy config response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day32-backend"'
                echo "$RESPONSE" | grep '"environment":"day32-env-file"'
                echo "$RESPONSE" | grep '"version":"day32-v1"'
                echo "$RESPONSE" | grep '"featureFlag":"enabled"'

                echo "Day 32 frontend API proxy smoke test passed."
                '''
            }
        }

        stage('Show Day 32 Deployment Diagnostics') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Day 32 Docker Compose service status:"
                    docker compose ps

                    echo "Day 32 containers:"
                    docker ps -a --filter "name=day32_"

                    echo "Day 32 backend health status:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                    echo "Recent Day 32 backend logs:"
                    docker logs --tail=30 "$BACKEND_CONTAINER" || true

                    echo "Recent Day 32 frontend logs:"
                    docker logs --tail=30 "$FRONTEND_CONTAINER" || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Day 32 pipeline completed successfully. Docker Compose health dependency validation passed.'
        }

        failure {
            echo 'Day 32 pipeline failed. Collecting failure diagnostics...'
        }

        always {
            dir("${PROJECT_DIR}") {
                sh '''
                echo "Final Day 32 Docker Compose status:"
                docker compose ps || true

                echo "Final Day 32 container list:"
                docker ps -a --filter "name=day32_" || true

                echo "Final Day 32 backend running state:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.State.Running}}' || true

                echo "Final Day 32 backend health:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                echo "Final Day 32 frontend running state:"
                docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}' || true

                echo "Final Day 32 backend logs:"
                docker logs --tail=50 "$BACKEND_CONTAINER" || true

                echo "Final Day 32 frontend logs:"
                docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                '''
            }
        }
    }
}
