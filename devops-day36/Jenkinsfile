pipeline {
    agent any
    environment {
        DOTENV = '.env'
    }
    stages {
        stage('Validate Jenkins Runtime') {
            steps {
                sh '''
                set -e
                echo "Validating Jenkins runtime tools..."
                git --version
                node --version
                npm --version
                docker --version
                docker compose version
                echo "Day 36 Jenkins runtime has required tools."
                '''
            }
        }
        stage('Validate Day 36 Project Files') {
            steps {
                sh '''
                set -e
                echo "Validating Day 36 required project files..."
                for f in backend/app.js backend/package.json backend/Dockerfile backend/.dockerignore frontend/index.html frontend/nginx.conf frontend/Dockerfile frontend/.dockerignore docker-compose.yml Jenkinsfile README.md .env; do
                  test -f $f
                done
                echo "All Day 36 required files found."
                '''
            }
        }
        stage('Validate .env File') {
            steps {
                sh '''
                set -e
                echo "Validating .env..."
                grep DAY36_BACKEND_PORT .env
                grep DAY36_BACKEND_HOST .env
                grep DAY36_FRONTEND_PORT .env
                grep DAY36_APP_ENV .env
                grep DAY36_APP_VERSION .env
                grep DAY36_FEATURE_FLAG .env
                echo ".env validation passed."
                '''
            }
        }
        stage('Build Docker Images') {
            steps {
                sh 'docker compose build --no-cache'
            }
        }
        stage('Deploy Application') {
            steps {
                sh 'docker compose up -d'
            }
        }
        stage('Wait for Backend Health') {
            steps {
                sh '''
                for i in $(seq 1 12); do
                    STATUS=$(docker inspect day36_backend --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                    echo "Backend health: $STATUS"
                    if [ "$STATUS" = "healthy" ]; then exit 0; fi
                    sleep 5
                done
                echo "Backend did not become healthy in time"
                exit 1
                '''
            }
        }
    }
}
