pipeline {
    agent any

    stages {
        stage('Check Required Files') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    test -f backend/app.js
                    test -f backend/package.json
                    test -f backend/Dockerfile
                    test -f frontend/index.html
                    test -f frontend/nginx.conf
                    test -f frontend/Dockerfile
                    test -f docker-compose.yml
                    echo "All required files are present"
                    '''
                }
            }
        }

        stage('Validate Backend File Exists and Is Readable') {
            steps {
                dir('devops-day22/backend') {
                    sh '''
                    set -e
                    test -s app.js
                    test -s package.json
                    echo "Backend files are readable and non-empty"
                    '''
                }
            }
        }

        stage('Validate Frontend File Exists and Is Readable') {
            steps {
                dir('devops-day22/frontend') {
                    sh '''
                    set -e
                    test -s index.html
                    test -s nginx.conf
                    echo "Frontend files are readable and non-empty"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Validation pipeline completed successfully'
        }
        failure {
            echo 'Validation pipeline failed'
        }
    }
}
