pipeline {
    agent any

    stages {
        stage('Check Required Files') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    test -f backend/app.js
                    test -f backend/package.json
                    test -f backend/Dockerfile
                    test -f frontend/index.html
                    test -f frontend/nginx.conf
                    test -f frontend/Dockerfile
                    test -f docker-compose.yml
                    echo "All required files are present"
                    '''
                }
            }
        }

        stage('Show Environment') {
            steps {
                sh '''
                set +e
                echo "Checking available tools..."
                which git || true
                git --version || true
                which node || true
                node --version || true
                which npm || true
                npm --version || true
                which docker || true
                docker --version || true
                docker compose version || true
                '''
            }
        }

        stage('Validate Backend Syntax') {
            steps {
                dir('devops-day22/backend') {
                    sh '''
                    set -e
                    node --check app.js
                    echo "Backend syntax validation passed"
                    '''
                }
            }
        }

        stage('Build Backend Image') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    docker build -t day22-backend ./backend
                    '''
                }
            }
        }

        stage('Build Frontend Image') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    docker build -t day22-frontend ./frontend
                    '''
                }
            }
        }

        stage('Deploy with Compose') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    docker compose down || true
                    docker compose up -d --build
                    '''
                }
            }
        }

        stage('Wait for Docker Health') {
            steps {
                sh '''
                set -e
                echo "Waiting for backend container health..."
                for i in $(seq 1 12); do
                  STATUS=$(docker inspect day22_backend --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                  echo "Current backend health: $STATUS"
                  if [ "$STATUS" = "healthy" ]; then
                    exit 0
                  fi
                  sleep 5
                done
                echo "Backend did not become healthy in time"
                exit 1
                '''
            }
        }

        stage('Verify Running Containers') {
            steps {
                sh '''
                set -e
                docker ps
                docker inspect day22_backend --format='{{.State.Status}} / {{.State.Health.Status}}'
                docker logs day22_backend || true
                docker logs day22_frontend || true
                '''
            }
        }
    }

    post {
        success {
            echo 'Day 26 pipeline completed successfully'
        }
        failure {
            echo 'Day 26 pipeline failed. Check container health and logs.'
        }
    }
}
