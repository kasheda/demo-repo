pipeline {
    agent any

    stages {
        stage('Check Required Files') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    test -f backend/app.js
                    test -f backend/package.json
                    test -f backend/Dockerfile
                    test -f frontend/index.html
                    test -f frontend/nginx.conf
                    test -f frontend/Dockerfile
                    test -f docker-compose.yml
                    echo "All required files are present"
                    '''
                }
            }
        }

        stage('Validate Backend Syntax') {
            steps {
                dir('devops-day22/backend') {
                    sh '''
                    set -e
                    npm install
                    node --check app.js
                    echo "Backend syntax validation passed"
                    '''
                }
            }
        }

        stage('Build Backend Image') {
            steps {
                dir('devops-day22') {
                    sh 'docker build -t day22-backend ./backend'
                }
            }
        }

        stage('Build Frontend Image') {
            steps {
                dir('devops-day22') {
                    sh 'docker build -t day22-frontend ./frontend'
                }
            }
        }

        stage('Deploy with Compose') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    docker-compose down || true
                    docker-compose up -d --build
                    '''
                }
            }
        }

        stage('Verify Containers') {
            steps {
                sh '''
                docker ps
                docker logs day22_backend || true
                docker logs day22_frontend || true
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully'
        }
        failure {
            echo 'Pipeline failed. Check the failed stage logs.'
        }
    }
}
