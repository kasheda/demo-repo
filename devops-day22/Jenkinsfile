pipeline {
    agent any

    stages {
        stage('Check Required Files') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    test -f backend/app.js
                    test -f backend/package.json
                    test -f backend/Dockerfile
                    test -f frontend/index.html
                    test -f frontend/nginx.conf
                    test -f frontend/Dockerfile
                    test -f docker-compose.yml
                    echo "All required files are present"
                    '''
                }
            }
        }

        stage('Show Environment') {
            steps {
                sh '''
                set +e
                echo "Checking available tools..."
                which git || true
                git --version || true
                which node || true
                node --version || true
                which npm || true
                npm --version || true
                which docker || true
                docker --version || true
                '''
            }
        }

        stage('Validate Backend Syntax If Node Exists') {
            steps {
                dir('devops-day22/backend') {
                    sh '''
                    set -e
                    if command -v node >/dev/null 2>&1; then
                      node --check app.js
                      echo "Backend syntax validation passed"
                    else
                      echo "Node is not installed in this Jenkins runtime"
                      exit 1
                    fi
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Day 23 pipeline completed successfully'
        }
        failure {
            echo 'Day 23 pipeline failed due to missing tools or invalid code'
        }
    }
}
