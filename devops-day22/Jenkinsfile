pipeline {
    agent any

    stages {
        stage('Check Required Files') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    test -f backend/app.js
                    test -f backend/package.json
                    test -f backend/Dockerfile
                    test -f frontend/index.html
                    test -f frontend/nginx.conf
                    test -f frontend/Dockerfile
                    test -f docker-compose.yml
                    echo "All required files are present"
                    '''
                }
            }
        }

        stage('Show Environment') {
            steps {
                sh '''
                set +e
                echo "Checking available tools..."
                which git || true
                git --version || true
                which node || true
                node --version || true
                which npm || true
                npm --version || true
                which docker || true
                docker --version || true
                docker compose version || true
                '''
            }
        }

        stage('Validate Backend Syntax') {
            steps {
                dir('devops-day22/backend') {
                    sh '''
                    set -e
                    node --check app.js
                    echo "Backend syntax validation passed"
                    '''
                }
            }
        }

        stage('Build Backend Image') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    docker build -t day22-backend ./backend
                    '''
                }
            }
        }

        stage('Build Frontend Image') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    docker build -t day22-frontend ./frontend
                    '''
                }
            }
        }

        stage('Deploy with Compose') {
            steps {
                dir('devops-day22') {
                    sh '''
                    set -e
                    docker compose down || true
                    docker compose up -d --build
                    '''
                }
            }
        }

        stage('Wait for App Startup') {
            steps {
                sh '''
                echo "Waiting 10 seconds for containers to start..."
                sleep 10
                '''
            }
        }

       stage('Verify Backend Health') {
    steps {
        sh '''
        set -e
        echo "Checking backend health from inside backend container..."
        docker exec day22_backend wget -qO- http://localhost:3000/health
        '''
    }
}

        stage('Verify Running Containers') {
            steps {
                sh '''
                set -e
                docker ps
                docker logs day22_backend || true
                docker logs day22_frontend || true
                '''
            }
        }
    }

    post {
        success {
            echo 'Day 25 pipeline completed successfully'
        }
        failure {
            echo 'Day 25 pipeline failed. Check logs and health verification stage.'
        }
    }
}
