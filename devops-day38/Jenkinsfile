pipeline {
    agent any

    parameters {
        choice(
            name: 'DEPLOY_ENV',
            choices: ['staging', 'dev', 'prodlike'],
            description: 'Choose which Day 38 environment Jenkins should deploy.'
        )
    }

    environment {
        DAY_NAME = 'Day 38'
        PROJECT_DIR = 'devops-day38'
        RUNTIME_ENV_FILE = '.env.runtime'
        BACKEND_CONTAINER = 'day38_backend'
        FRONTEND_CONTAINER = 'day38_frontend'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code for Day 38...'
                checkout scm
            }
        }

        stage('Select Day 38 Environment File') {
            steps {
                script {
                    if (params.DEPLOY_ENV == 'dev') {
                        env.BASE_ENV_FILE = '.env'
                        env.EXPECTED_APP_ENV = 'day38-dev-env'
                        env.EXPECTED_DEPLOY_TARGET = 'dev'
                        env.EXPECTED_APP_VERSION = 'day38-dev-v1'
                        env.EXPECTED_FEATURE_FLAG = 'enabled'
                        env.EXPECTED_FRONTEND_PORT = '8038'
                    } else if (params.DEPLOY_ENV == 'staging') {
                        env.BASE_ENV_FILE = '.env.staging'
                        env.EXPECTED_APP_ENV = 'day38-staging-env'
                        env.EXPECTED_DEPLOY_TARGET = 'staging'
                        env.EXPECTED_APP_VERSION = 'day38-staging-v1'
                        env.EXPECTED_FEATURE_FLAG = 'enabled'
                        env.EXPECTED_FRONTEND_PORT = '8138'
                    } else if (params.DEPLOY_ENV == 'prodlike') {
                        env.BASE_ENV_FILE = '.env.prodlike'
                        env.EXPECTED_APP_ENV = 'day38-prodlike-env'
                        env.EXPECTED_DEPLOY_TARGET = 'prodlike'
                        env.EXPECTED_APP_VERSION = 'day38-prodlike-v1'
                        env.EXPECTED_FEATURE_FLAG = 'disabled'
                        env.EXPECTED_FRONTEND_PORT = '8238'
                    } else {
                        error "Unsupported Day 38 DEPLOY_ENV: ${params.DEPLOY_ENV}"
                    }

                    echo "Day 38 selected DEPLOY_ENV=${params.DEPLOY_ENV}"
                    echo "Day 38 selected BASE_ENV_FILE=${env.BASE_ENV_FILE}"
                }
            }
        }

        stage('Validate Day 38 Jenkins Runtime') {
            steps {
                sh '''
                set -e

                echo "Validating Day 38 Jenkins runtime tools..."

                git --version
                node --version
                npm --version
                docker --version
                docker compose version

                echo "Day 38 Jenkins runtime has required tools."
                '''
            }
        }

        stage('Validate Day 38 Project Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 38 required project files..."

                    REQUIRED_FILES="
backend/app.js
backend/package.json
backend/Dockerfile
backend/.dockerignore
frontend/index.html
frontend/nginx.conf
frontend/Dockerfile
frontend/.dockerignore
.env
.env.staging
.env.prodlike
.env.example
docker-compose.yml
Jenkinsfile
README.md
"

                    for file in $REQUIRED_FILES; do
                      if [ ! -f "$file" ]; then
                        echo "Missing required Day 38 file: $file"
                        echo "Current Day 38 files:"
                        find . -maxdepth 3 -type f | sort
                        exit 1
                      fi

                      echo "Found Day 38 file: $file"
                    done

                    echo "All Day 38 required files found."
                    '''
                }
            }
        }

        stage('Generate Day 38 Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Generating Day 38 runtime env file from $BASE_ENV_FILE..."

                    GIT_COMMIT_SHORT=$(git rev-parse --short HEAD)
                    BUILD_NUMBER_VALUE="${BUILD_NUMBER:-local}"
                    IMAGE_TAG="day38-${DEPLOY_ENV}-${BUILD_NUMBER_VALUE}-${GIT_COMMIT_SHORT}"

                    grep -v '^DAY38_BUILD_NUMBER=' "$BASE_ENV_FILE" \
                      | grep -v '^DAY38_GIT_COMMIT=' \
                      | grep -v '^DAY38_IMAGE_TAG=' > "$RUNTIME_ENV_FILE"

                    {
                      echo "DAY38_BUILD_NUMBER=$BUILD_NUMBER_VALUE"
                      echo "DAY38_GIT_COMMIT=$GIT_COMMIT_SHORT"
                      echo "DAY38_IMAGE_TAG=$IMAGE_TAG"
                    } >> "$RUNTIME_ENV_FILE"

                    echo "Day 38 runtime env file:"
                    cat "$RUNTIME_ENV_FILE"

                    echo "DAY38_EXPECTED_BUILD_NUMBER=$BUILD_NUMBER_VALUE" > day38-build-metadata.env
                    echo "DAY38_EXPECTED_GIT_COMMIT=$GIT_COMMIT_SHORT" >> day38-build-metadata.env
                    echo "DAY38_EXPECTED_IMAGE_TAG=$IMAGE_TAG" >> day38-build-metadata.env
                    '''
                }
            }
        }

        stage('Load Day 38 Build Metadata') {
            steps {
                dir("${PROJECT_DIR}") {
                    script {
                        def props = readProperties file: 'day38-build-metadata.env'
                        env.EXPECTED_BUILD_NUMBER = props['DAY38_EXPECTED_BUILD_NUMBER']
                        env.EXPECTED_GIT_COMMIT = props['DAY38_EXPECTED_GIT_COMMIT']
                        env.EXPECTED_IMAGE_TAG = props['DAY38_EXPECTED_IMAGE_TAG']

                        echo "Day 38 expected build number: ${env.EXPECTED_BUILD_NUMBER}"
                        echo "Day 38 expected git commit: ${env.EXPECTED_GIT_COMMIT}"
                        echo "Day 38 expected image tag: ${env.EXPECTED_IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Validate Day 38 Backend Syntax') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Validating Day 38 backend JavaScript syntax..."
                    node --check app.js

                    echo "Day 38 backend syntax is valid."
                    '''
                }
            }
        }

        stage('Validate Day 38 Frontend Files') {
            steps {
                dir("${PROJECT_DIR}/frontend") {
                    sh '''
                    set -e

                    echo "Validating Day 38 frontend files..."

                    test -s index.html
                    test -s nginx.conf

                    grep "DevOps Day 38" index.html
                    grep "day38-backend" nginx.conf
                    grep "X-Request-Id" nginx.conf
                    grep "/metrics" nginx.conf
                    grep "/api/version" index.html

                    if grep -q '\\${DAY38' nginx.conf; then
                      echo "Day 38 nginx.conf should not contain unresolved env placeholders."
                      exit 1
                    fi

                    echo "Day 38 frontend files are valid."
                    '''
                }
            }
        }

        stage('Validate Day 38 Env Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 38 dev env file..."
                    grep "DAY38_APP_ENV=day38-dev-env" .env
                    grep "DAY38_DEPLOY_TARGET=dev" .env
                    grep "DAY38_APP_VERSION=day38-dev-v1" .env
                    grep "DAY38_FEATURE_FLAG=enabled" .env
                    grep "DAY38_FRONTEND_PORT=8038" .env

                    echo "Validating Day 38 staging env file..."
                    grep "DAY38_APP_ENV=day38-staging-env" .env.staging
                    grep "DAY38_DEPLOY_TARGET=staging" .env.staging
                    grep "DAY38_APP_VERSION=day38-staging-v1" .env.staging
                    grep "DAY38_FEATURE_FLAG=enabled" .env.staging
                    grep "DAY38_FRONTEND_PORT=8138" .env.staging

                    echo "Validating Day 38 prodlike env file..."
                    grep "DAY38_APP_ENV=day38-prodlike-env" .env.prodlike
                    grep "DAY38_DEPLOY_TARGET=prodlike" .env.prodlike
                    grep "DAY38_APP_VERSION=day38-prodlike-v1" .env.prodlike
                    grep "DAY38_FEATURE_FLAG=disabled" .env.prodlike
                    grep "DAY38_FRONTEND_PORT=8238" .env.prodlike

                    echo "Day 38 env file value validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 38 Selected Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating selected Day 38 runtime env file: $RUNTIME_ENV_FILE"

                    grep "DAY38_APP_ENV=$EXPECTED_APP_ENV" "$RUNTIME_ENV_FILE"
                    grep "DAY38_DEPLOY_TARGET=$EXPECTED_DEPLOY_TARGET" "$RUNTIME_ENV_FILE"
                    grep "DAY38_APP_VERSION=$EXPECTED_APP_VERSION" "$RUNTIME_ENV_FILE"
                    grep "DAY38_FEATURE_FLAG=$EXPECTED_FEATURE_FLAG" "$RUNTIME_ENV_FILE"
                    grep "DAY38_FRONTEND_PORT=$EXPECTED_FRONTEND_PORT" "$RUNTIME_ENV_FILE"
                    grep "DAY38_BUILD_NUMBER=$EXPECTED_BUILD_NUMBER" "$RUNTIME_ENV_FILE"
                    grep "DAY38_GIT_COMMIT=$EXPECTED_GIT_COMMIT" "$RUNTIME_ENV_FILE"
                    grep "DAY38_IMAGE_TAG=$EXPECTED_IMAGE_TAG" "$RUNTIME_ENV_FILE"

                    echo "Selected Day 38 runtime env file matches DEPLOY_ENV=$DEPLOY_ENV."
                    '''
                }
            }
        }

        stage('Validate Day 38 Env Key Drift') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Checking Day 38 env key drift..."

                    cut -d '=' -f 1 .env | grep -v '^$' | sort > day38-env-keys.txt
                    cut -d '=' -f 1 .env.staging | grep -v '^$' | sort > day38-staging-env-keys.txt
                    cut -d '=' -f 1 .env.prodlike | grep -v '^$' | sort > day38-prodlike-env-keys.txt
                    cut -d '=' -f 1 .env.example | grep -v '^$' | sort > day38-env-example-keys.txt

                    diff -u day38-env-example-keys.txt day38-env-keys.txt
                    diff -u day38-env-example-keys.txt day38-staging-env-keys.txt
                    diff -u day38-env-example-keys.txt day38-prodlike-env-keys.txt

                    rm -f day38-env-keys.txt day38-staging-env-keys.txt day38-prodlike-env-keys.txt day38-env-example-keys.txt

                    echo "Day 38 env files contain the same keys."
                    '''
                }
            }
        }

        stage('Validate Day 38 Build Metadata Code') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Validating Day 38 build metadata code..."

                    grep "BUILD_NUMBER" app.js
                    grep "GIT_COMMIT" app.js
                    grep "IMAGE_TAG" app.js
                    grep "buildMetadata" app.js
                    grep "app.get('/api/version'" app.js

                    echo "Day 38 build metadata code validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 38 Metrics and Logging Code') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Validating Day 38 metrics and logging code..."

                    grep "METRICS_ENABLED" app.js
                    grep "totalRequests" app.js
                    grep "requestsByPath" app.js
                    grep "statusCodes" app.js
                    grep "request_completed" app.js
                    grep "controlled_error_test_triggered" app.js

                    echo "Day 38 metrics and logging code validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 38 Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 38 Docker Compose config..."

                    grep "condition: service_healthy" docker-compose.yml
                    grep "healthcheck:" docker-compose.yml
                    grep "day38-backend:" docker-compose.yml
                    grep "day38-backend:\\${DAY38_IMAGE_TAG}" docker-compose.yml
                    grep "day38-frontend:\\${DAY38_IMAGE_TAG}" docker-compose.yml
                    grep "http://127.0.0.1:3000/health" docker-compose.yml

                    if grep -q "broken-health" docker-compose.yml; then
                      echo "Day 38 docker-compose.yml contains broken-health."
                      exit 1
                    fi

                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_APP_ENV"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_DEPLOY_TARGET"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_IMAGE_TAG"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "http://127.0.0.1:3000/health"

                    echo "Day 38 Compose validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 38 App Fails Without Required Env') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Testing that Day 38 backend fails fast without required environment variables..."

                    set +e
                    env -u PORT \
    -u APP_ENV \
    -u APP_VERSION \
    -u SERVICE_NAME \
    -u FEATURE_FLAG \
    -u LOG_LEVEL \
    -u METRICS_ENABLED \
    -u DEPLOY_TARGET \
    -u BUILD_NUMBER \
    -u GIT_COMMIT \
    -u IMAGE_TAG \
    node app.js > day38-missing-env.log 2>&1
                    EXIT_CODE=$?
                    set -e

                    cat day38-missing-env.log

                    if [ "$EXIT_CODE" -eq 0 ]; then
                      echo "Day 38 backend unexpectedly started without required environment variables."
                      rm -f day38-missing-env.log
                      exit 1
                    fi

                    grep "Missing required environment variables" day38-missing-env.log
                    grep "BUILD_NUMBER" day38-missing-env.log
                    grep "GIT_COMMIT" day38-missing-env.log
                    grep "IMAGE_TAG" day38-missing-env.log

                    rm -f day38-missing-env.log

                    echo "Day 38 backend correctly fails when required environment variables are missing."
                    '''
                }
            }
        }

        stage('Render Day 38 Docker Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Rendering Day 38 Docker Compose config with runtime env file: $RUNTIME_ENV_FILE"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config

                    echo "Day 38 Docker Compose config rendered successfully."
                    '''
                }
            }
        }

        stage('Build Day 38 Docker Images') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Building Day 38 Docker images with tag: $EXPECTED_IMAGE_TAG"
                    docker compose --env-file "$RUNTIME_ENV_FILE" build --no-cache

                    echo "Listing Day 38 images:"
                    docker images | grep "day38-" || true

                    echo "Day 38 Docker images built successfully."
                    '''
                }
            }
        }

        stage('Deploy Day 38 With Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Stopping old Day 38 containers if they exist..."
                    docker compose --env-file "$RUNTIME_ENV_FILE" down || true

                    echo "Starting Day 38 application using runtime env file: $RUNTIME_ENV_FILE"
                    docker compose --env-file "$RUNTIME_ENV_FILE" up -d

                    echo "Current Day 38 containers:"
                    docker ps --filter "name=day38_"
                    '''
                }
            }
        }

        stage('Verify Day 38 Frontend Waited for Backend Health') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    BACKEND_HEALTH=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                    FRONTEND_RUNNING=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}' 2>/dev/null || echo "unknown")

                    echo "Day 38 backend health: $BACKEND_HEALTH"
                    echo "Day 38 frontend running: $FRONTEND_RUNNING"

                    if [ "$BACKEND_HEALTH" != "healthy" ]; then
                      docker logs --tail=50 "$BACKEND_CONTAINER" || true
                      exit 1
                    fi

                    if [ "$FRONTEND_RUNNING" != "true" ]; then
                      docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                      exit 1
                    fi

                    echo "Day 38 frontend is running after backend became healthy."
                    '''
                }
            }
        }

        stage('Smoke Test Day 38 Backend Health') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-health-smoke' http://127.0.0.1:3000/health")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"status":"ok"'
                echo "$RESPONSE" | grep '"service":"day38-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"version\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$RESPONSE" | grep "\\"buildNumber\\":\\"$EXPECTED_BUILD_NUMBER\\""
                echo "$RESPONSE" | grep "\\"gitCommit\\":\\"$EXPECTED_GIT_COMMIT\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 38 backend health smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 38 Version Endpoint') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-version-smoke' http://127.0.0.1:3000/api/version")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day38-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"appVersion\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$RESPONSE" | grep "\\"buildNumber\\":\\"$EXPECTED_BUILD_NUMBER\\""
                echo "$RESPONSE" | grep "\\"gitCommit\\":\\"$EXPECTED_GIT_COMMIT\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""
                echo "$RESPONSE" | grep '"requestId":"day38-version-smoke"'

                echo "Day 38 version endpoint smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 38 Backend API') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-api-smoke' http://127.0.0.1:3000/api/message")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep 'Hello from Day 38 backend API'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"featureFlag\\":\\"$EXPECTED_FEATURE_FLAG\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 38 backend API smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 38 Runtime Config') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-config-smoke' http://127.0.0.1:3000/api/config")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day38-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"version\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$RESPONSE" | grep "\\"featureFlag\\":\\"$EXPECTED_FEATURE_FLAG\\""
                echo "$RESPONSE" | grep '"metricsEnabled":true'
                echo "$RESPONSE" | grep "\\"buildNumber\\":\\"$EXPECTED_BUILD_NUMBER\\""
                echo "$RESPONSE" | grep "\\"gitCommit\\":\\"$EXPECTED_GIT_COMMIT\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 38 runtime config smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 38 Controlled Error') {
            steps {
                sh '''
                set -e

                set +e
                docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-error-smoke' http://127.0.0.1:3000/api/error-test"
                EXIT_CODE=$?
                set -e

                if [ "$EXIT_CODE" -eq 0 ]; then
                  echo "Day 38 error-test unexpectedly returned success."
                  exit 1
                fi

                echo "Day 38 controlled error endpoint returned failure as expected."
                '''
            }
        }

        stage('Smoke Test Day 38 Metrics') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-metrics-smoke' http://127.0.0.1:3000/metrics")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day38-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep '"metricsEnabled":true'
                echo "$RESPONSE" | grep '"totalRequests"'
                echo "$RESPONSE" | grep '"requestsByPath"'
                echo "$RESPONSE" | grep '"statusCodes"'
                echo "$RESPONSE" | grep '"/api/version"'
                echo "$RESPONSE" | grep '"/api/message"'
                echo "$RESPONSE" | grep '"/api/config"'
                echo "$RESPONSE" | grep '"/api/error-test"'
                echo "$RESPONSE" | grep '"200"'
                echo "$RESPONSE" | grep '"500"'
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 38 metrics smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 38 Frontend Page') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep 'DevOps Day 38'
                echo "$RESPONSE" | grep 'Jenkins build metadata'
                echo "$RESPONSE" | grep 'Backend Version'

                echo "Day 38 frontend page smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 38 Frontend API Proxy') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-proxy-smoke' http://127.0.0.1/api/config")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day38-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 38 frontend API proxy smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 38 Frontend Version Proxy') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day38-proxy-version-smoke' http://127.0.0.1/api/version")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day38-backend"'
                echo "$RESPONSE" | grep "\\"gitCommit\\":\\"$EXPECTED_GIT_COMMIT\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 38 frontend version proxy smoke test passed."
                '''
            }
        }

        stage('Verify Day 38 Backend Logs') {
            steps {
                sh '''
                set -e

                LOGS=$(docker logs "$BACKEND_CONTAINER" 2>&1)

                echo "$LOGS" | grep 'request_completed'
                echo "$LOGS" | grep 'day38-api-smoke'
                echo "$LOGS" | grep 'day38-config-smoke'
                echo "$LOGS" | grep 'day38-version-smoke'
                echo "$LOGS" | grep 'controlled_error_test_triggered'
                echo "$LOGS" | grep '"statusCode":200'
                echo "$LOGS" | grep '"statusCode":500'
                echo "$LOGS" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$LOGS" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 38 backend logs contain request IDs, deployment target, image tag, and error evidence."
                '''
            }
        }

        stage('Show Day 38 Deployment Diagnostics') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Day 38 selected DEPLOY_ENV: $DEPLOY_ENV"
                    echo "Day 38 base env file: $BASE_ENV_FILE"
                    echo "Day 38 runtime env file: $RUNTIME_ENV_FILE"
                    echo "Day 38 expected image tag: $EXPECTED_IMAGE_TAG"

                    echo "Day 38 Docker Compose service status:"
                    docker compose --env-file "$RUNTIME_ENV_FILE" ps

                    echo "Day 38 containers:"
                    docker ps -a --filter "name=day38_"

                    echo "Day 38 backend image:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true

                    echo "Day 38 frontend image:"
                    docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}' || true

                    echo "Day 38 backend health status:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                    echo "Recent Day 38 backend logs:"
                    docker logs --tail=120 "$BACKEND_CONTAINER" || true

                    echo "Recent Day 38 frontend logs:"
                    docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Day 38 pipeline completed successfully. Build metadata and image tag verification passed.'
        }

        failure {
            echo 'Day 38 pipeline failed. Collecting failure diagnostics...'
        }

        always {
            dir("${PROJECT_DIR}") {
                sh '''
                echo "Final Day 38 selected DEPLOY_ENV:"
                echo "$DEPLOY_ENV"

                echo "Final Day 38 runtime env file:"
                echo "$RUNTIME_ENV_FILE"

                echo "Final Day 38 Docker Compose status:"
                docker compose --env-file "$RUNTIME_ENV_FILE" ps || true

                echo "Final Day 38 container list:"
                docker ps -a --filter "name=day38_" || true

                echo "Final Day 38 backend image:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true

                echo "Final Day 38 frontend image:"
                docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}' || true

                echo "Final Day 38 backend health:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                echo "Final Day 38 backend logs:"
                docker logs --tail=120 "$BACKEND_CONTAINER" || true

                echo "Final Day 38 frontend logs:"
                docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                '''
            }
        }
    }
}
