pipeline {
    agent any

    environment {
        DAY_NAME = 'Day 31'
        PROJECT_DIR = 'devops-day31'
        BACKEND_CONTAINER = 'day31_backend'
        FRONTEND_CONTAINER = 'day31_frontend'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code for Day 31...'
                checkout scm
            }
        }

        stage('Validate Day 31 Jenkins Runtime') {
            steps {
                sh '''
                set -e

                echo "Validating Day 31 Jenkins runtime tools..."

                git --version
                node --version
                npm --version
                docker --version
                docker compose version

                echo "Day 31 Jenkins runtime has required tools."
                '''
            }
        }

        stage('Validate Day 31 Project Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 31 required project files..."

                    REQUIRED_FILES="
backend/app.js
backend/package.json
backend/Dockerfile
backend/.dockerignore
frontend/index.html
frontend/nginx.conf
frontend/Dockerfile
frontend/.dockerignore
.env
docker-compose.yml
Jenkinsfile
README.md
"

                    for file in $REQUIRED_FILES; do
                      if [ ! -f "$file" ]; then
                        echo "Missing required Day 31 file: $file"
                        echo "Current Day 31 files:"
                        find . -maxdepth 3 -type f | sort
                        exit 1
                      fi

                      echo "Found Day 31 file: $file"
                    done

                    echo "All Day 31 required files found."
                    '''
                }
            }
        }

        stage('Validate Day 31 Backend Syntax') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Validating Day 31 backend JavaScript syntax..."
                    node --check app.js

                    echo "Day 31 backend syntax is valid."
                    '''
                }
            }
        }

        stage('Validate Day 31 Frontend Files') {
            steps {
                dir("${PROJECT_DIR}/frontend") {
                    sh '''
                    set -e

                    echo "Validating Day 31 frontend files..."

                    test -s index.html
                    test -s nginx.conf

                    grep "DevOps Day 31" index.html
                    grep "day31-backend" nginx.conf

                    echo "Day 31 frontend files are valid."
                    '''
                }
            }
        }

        stage('Validate Day 31 Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 31 .env file..."

                    REQUIRED_ENV_KEYS="
DAY31_BACKEND_PORT=3000
DAY31_FRONTEND_PORT=8080
DAY31_APP_ENV=day31-env-file
DAY31_APP_VERSION=day31-v1
DAY31_SERVICE_NAME=day31-backend
DAY31_FEATURE_FLAG=enabled
"

                    for key in $REQUIRED_ENV_KEYS; do
                      grep "$key" .env
                      echo "Found Day 31 env value: $key"
                    done

                    echo "Day 31 .env file validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 31 App Fails Without Required Env') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Testing that Day 31 backend fails fast without required environment variables..."

                    set +e
                    node app.js > day31-missing-env.log 2>&1
                    EXIT_CODE=$?
                    set -e

                    cat day31-missing-env.log

                    if [ "$EXIT_CODE" -eq 0 ]; then
                      echo "Day 31 backend unexpectedly started without required environment variables."
                      exit 1
                    fi

                    grep "Missing required environment variables" day31-missing-env.log

                    rm -f day31-missing-env.log

                    echo "Day 31 backend correctly fails when required environment variables are missing."
                    '''
                }
            }
        }

        stage('Render Day 31 Docker Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Rendering Day 31 Docker Compose config with .env values..."
                    docker compose config

                    echo "Day 31 Docker Compose config rendered successfully."
                    '''
                }
            }
        }

        stage('Build Day 31 Docker Images') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Building Day 31 Docker images without cache..."
                    docker compose build --no-cache

                    echo "Day 31 Docker images built successfully."
                    '''
                }
            }
        }

        stage('Deploy Day 31 With Docker Compose') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Stopping old Day 31 containers if they exist..."
                    docker compose down || true

                    echo "Starting Day 31 application..."
                    docker compose up -d

                    echo "Current Day 31 containers:"
                    docker ps --filter "name=day31_"
                    '''
                }
            }
        }

        stage('Wait for Day 31 Docker Health') {
            steps {
                sh '''
                set -e

                echo "Waiting for Day 31 backend container health..."

                for i in $(seq 1 12); do
                  STATUS=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                  RUNNING=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Running}}' 2>/dev/null || echo "unknown")

                  echo "Attempt $i: Day 31 backend running = $RUNNING, health = $STATUS"

                  if [ "$STATUS" = "healthy" ]; then
                    echo "Day 31 backend container is healthy."
                    exit 0
                  fi

                  if [ "$RUNNING" = "false" ]; then
                    echo "Day 31 backend container stopped before becoming healthy."
                    echo "Recent Day 31 backend logs:"
                    docker logs --tail=50 "$BACKEND_CONTAINER" || true
                    exit 1
                  fi

                  if [ "$STATUS" = "unhealthy" ]; then
                    echo "Day 31 backend container is unhealthy."
                    echo "Recent Day 31 backend logs:"
                    docker logs --tail=50 "$BACKEND_CONTAINER" || true
                    exit 1
                  fi

                  sleep 5
                done

                echo "Day 31 backend did not become healthy in time."
                echo "Final Day 31 backend inspect:"
                docker inspect "$BACKEND_CONTAINER" || true

                echo "Recent Day 31 backend logs:"
                docker logs --tail=50 "$BACKEND_CONTAINER" || true

                exit 1
                '''
            }
        }

        stage('Smoke Test Day 31 Backend Health') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 31 backend health endpoint..."
                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1:3000/health")

                echo "Day 31 backend health response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"status":"ok"'
                echo "$RESPONSE" | grep '"service":"day31-backend"'
                echo "$RESPONSE" | grep '"environment":"day31-env-file"'
                echo "$RESPONSE" | grep '"version":"day31-v1"'

                echo "Day 31 backend health smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 31 Backend API') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 31 backend API endpoint..."
                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1:3000/api/message")

                echo "Day 31 backend API response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep 'Hello from Day 31 backend API'
                echo "$RESPONSE" | grep '"service":"day31-backend"'
                echo "$RESPONSE" | grep '"environment":"day31-env-file"'
                echo "$RESPONSE" | grep '"featureFlag":"enabled"'

                echo "Day 31 backend API smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 31 Runtime Config') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 31 runtime config endpoint..."
                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1:3000/api/config")

                echo "Day 31 runtime config response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day31-backend"'
                echo "$RESPONSE" | grep '"environment":"day31-env-file"'
                echo "$RESPONSE" | grep '"version":"day31-v1"'
                echo "$RESPONSE" | grep '"featureFlag":"enabled"'
                echo "$RESPONSE" | grep '"port":3000'

                echo "Day 31 runtime config smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 31 Frontend Page') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 31 frontend page..."
                RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/")

                echo "Day 31 frontend page response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep 'DevOps Day 31'
                echo "$RESPONSE" | grep 'Backend Required Runtime Config'

                echo "Day 31 frontend page smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 31 Frontend API Proxy') {
            steps {
                sh '''
                set -e

                echo "Smoke testing Day 31 frontend-to-backend proxy..."
                RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/api/config")

                echo "Day 31 frontend proxy config response:"
                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day31-backend"'
                echo "$RESPONSE" | grep '"environment":"day31-env-file"'
                echo "$RESPONSE" | grep '"version":"day31-v1"'
                echo "$RESPONSE" | grep '"featureFlag":"enabled"'

                echo "Day 31 frontend API proxy smoke test passed."
                '''
            }
        }

        stage('Show Day 31 Deployment Diagnostics') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Day 31 Docker Compose service status:"
                    docker compose ps

                    echo "Day 31 containers:"
                    docker ps -a --filter "name=day31_"

                    echo "Day 31 backend health status:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                    echo "Recent Day 31 backend logs:"
                    docker logs --tail=30 "$BACKEND_CONTAINER" || true

                    echo "Recent Day 31 frontend logs:"
                    docker logs --tail=30 "$FRONTEND_CONTAINER" || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Day 31 pipeline completed successfully. Required environment validation passed.'
        }

        failure {
            echo 'Day 31 pipeline failed. Collecting failure diagnostics...'
        }

        always {
            dir("${PROJECT_DIR}") {
                sh '''
                echo "Final Day 31 Docker Compose status:"
                docker compose ps || true

                echo "Final Day 31 container list:"
                docker ps -a --filter "name=day31_" || true

                echo "Final Day 31 backend running state:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.State.Running}}' || true

                echo "Final Day 31 backend health:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                echo "Final Day 31 backend logs:"
                docker logs --tail=50 "$BACKEND_CONTAINER" || true

                echo "Final Day 31 frontend logs:"
                docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                '''
            }
        }
    }
}
