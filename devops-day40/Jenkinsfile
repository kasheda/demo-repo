pipeline {
    agent any

    parameters {
        choice(
            name: 'DEPLOY_ENV',
            choices: ['staging', 'dev', 'prodlike'],
            description: 'Choose which Day 40 environment Jenkins should deploy.'
        )
    }

    environment {
        DAY_NAME = 'Day 40'
        PROJECT_DIR = 'devops-day40'
        RUNTIME_ENV_FILE = '.env.runtime'
        BACKEND_CONTAINER = 'day40_backend'
        FRONTEND_CONTAINER = 'day40_frontend'
        AUDIT_DIR = 'deployment-audit'
        AUDIT_JSON = 'deployment-audit/day40-deployment-audit.json'
        AUDIT_TEXT = 'deployment-audit/day40-deployment-audit.txt'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code for Day 40...'
                checkout scm
            }
        }

        stage('Select Day 40 Environment File') {
            steps {
                script {
                    if (params.DEPLOY_ENV == 'dev') {
                        env.BASE_ENV_FILE = '.env'
                        env.EXPECTED_APP_ENV = 'day40-dev-env'
                        env.EXPECTED_DEPLOY_TARGET = 'dev'
                        env.EXPECTED_APP_VERSION = 'day40-dev-v1'
                        env.EXPECTED_FEATURE_FLAG = 'enabled'
                        env.EXPECTED_FRONTEND_PORT = '8040'
                    } else if (params.DEPLOY_ENV == 'staging') {
                        env.BASE_ENV_FILE = '.env.staging'
                        env.EXPECTED_APP_ENV = 'day40-staging-env'
                        env.EXPECTED_DEPLOY_TARGET = 'staging'
                        env.EXPECTED_APP_VERSION = 'day40-staging-v1'
                        env.EXPECTED_FEATURE_FLAG = 'enabled'
                        env.EXPECTED_FRONTEND_PORT = '8140'
                    } else if (params.DEPLOY_ENV == 'prodlike') {
                        env.BASE_ENV_FILE = '.env.prodlike'
                        env.EXPECTED_APP_ENV = 'day40-prodlike-env'
                        env.EXPECTED_DEPLOY_TARGET = 'prodlike'
                        env.EXPECTED_APP_VERSION = 'day40-prodlike-v1'
                        env.EXPECTED_FEATURE_FLAG = 'disabled'
                        env.EXPECTED_FRONTEND_PORT = '8240'
                    } else {
                        error "Unsupported Day 40 DEPLOY_ENV: ${params.DEPLOY_ENV}"
                    }

                    echo "Day 40 selected DEPLOY_ENV=${params.DEPLOY_ENV}"
                    echo "Day 40 selected BASE_ENV_FILE=${env.BASE_ENV_FILE}"
                }
            }
        }

        stage('Validate Day 40 Jenkins Runtime') {
            steps {
                sh '''
                set -e

                echo "Validating Day 40 Jenkins runtime tools..."

                git --version
                node --version
                npm --version
                docker --version
                docker compose version

                echo "Day 40 Jenkins runtime has required tools."
                '''
            }
        }

        stage('Validate Day 40 Project Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 40 required project files..."

                    REQUIRED_FILES="
backend/app.js
backend/package.json
backend/Dockerfile
backend/.dockerignore
frontend/index.html
frontend/nginx.conf
frontend/Dockerfile
frontend/.dockerignore
deployment-audit/.gitkeep
.env
.env.staging
.env.prodlike
.env.example
docker-compose.yml
Jenkinsfile
README.md
"

                    for file in $REQUIRED_FILES; do
                      if [ ! -f "$file" ]; then
                        echo "Missing required Day 40 file: $file"
                        echo "Current Day 40 files:"
                        find . -maxdepth 3 -type f | sort
                        exit 1
                      fi

                      echo "Found Day 40 file: $file"
                    done

                    echo "All Day 40 required files found."
                    '''
                }
            }
        }

        stage('Generate Day 40 Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Generating Day 40 runtime env file from $BASE_ENV_FILE..."

                    GIT_COMMIT_SHORT=$(git rev-parse --short HEAD)
                    BUILD_NUMBER_VALUE="${BUILD_NUMBER:-local}"
                    RELEASE_CREATED_AT=$(date -u +%Y-%m-%dT%H-%M-%SZ)
                    IMAGE_TAG="day40-${DEPLOY_ENV}-${BUILD_NUMBER_VALUE}-${GIT_COMMIT_SHORT}"

                    grep -v '^DAY40_BUILD_NUMBER=' "$BASE_ENV_FILE" \
                      | grep -v '^DAY40_GIT_COMMIT=' \
                      | grep -v '^DAY40_IMAGE_TAG=' \
                      | grep -v '^DAY40_RELEASE_CREATED_AT=' > "$RUNTIME_ENV_FILE"

                    {
                      echo "DAY40_BUILD_NUMBER=$BUILD_NUMBER_VALUE"
                      echo "DAY40_GIT_COMMIT=$GIT_COMMIT_SHORT"
                      echo "DAY40_IMAGE_TAG=$IMAGE_TAG"
                      echo "DAY40_RELEASE_CREATED_AT=$RELEASE_CREATED_AT"
                    } >> "$RUNTIME_ENV_FILE"

                    echo "Day 40 runtime env file:"
                    cat "$RUNTIME_ENV_FILE"

                    echo "DAY40_EXPECTED_BUILD_NUMBER=$BUILD_NUMBER_VALUE" > day40-build-metadata.env
                    echo "DAY40_EXPECTED_GIT_COMMIT=$GIT_COMMIT_SHORT" >> day40-build-metadata.env
                    echo "DAY40_EXPECTED_IMAGE_TAG=$IMAGE_TAG" >> day40-build-metadata.env
                    echo "DAY40_EXPECTED_RELEASE_CREATED_AT=$RELEASE_CREATED_AT" >> day40-build-metadata.env
                    '''
                }
            }
        }

        stage('Load Day 40 Build Metadata') {
            steps {
                dir("${PROJECT_DIR}") {
                    script {
                        env.EXPECTED_BUILD_NUMBER = sh(
                            returnStdout: true,
                            script: ". ./day40-build-metadata.env && echo \$DAY40_EXPECTED_BUILD_NUMBER"
                        ).trim()

                        env.EXPECTED_GIT_COMMIT = sh(
                            returnStdout: true,
                            script: ". ./day40-build-metadata.env && echo \$DAY40_EXPECTED_GIT_COMMIT"
                        ).trim()

                        env.EXPECTED_IMAGE_TAG = sh(
                            returnStdout: true,
                            script: ". ./day40-build-metadata.env && echo \$DAY40_EXPECTED_IMAGE_TAG"
                        ).trim()

                        env.EXPECTED_RELEASE_CREATED_AT = sh(
                            returnStdout: true,
                            script: ". ./day40-build-metadata.env && echo \$DAY40_EXPECTED_RELEASE_CREATED_AT"
                        ).trim()

                        echo "Day 40 expected build number: ${env.EXPECTED_BUILD_NUMBER}"
                        echo "Day 40 expected git commit: ${env.EXPECTED_GIT_COMMIT}"
                        echo "Day 40 expected image tag: ${env.EXPECTED_IMAGE_TAG}"
                        echo "Day 40 expected release created at: ${env.EXPECTED_RELEASE_CREATED_AT}"
                    }
                }
            }
        }

        stage('Validate Day 40 Backend Syntax') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Validating Day 40 backend JavaScript syntax..."
                    node --check app.js

                    echo "Day 40 backend syntax is valid."
                    '''
                }
            }
        }

        stage('Validate Day 40 Frontend Files') {
            steps {
                dir("${PROJECT_DIR}/frontend") {
                    sh '''
                    set -e

                    echo "Validating Day 40 frontend files..."

                    test -s index.html
                    test -s nginx.conf

                    grep "DevOps Day 40" index.html
                    grep "day40-backend" nginx.conf
                    grep "X-Request-Id" nginx.conf
                    grep "/metrics" nginx.conf
                    grep "/api/version" index.html
                    grep "/api/release" index.html
                    grep "/api/audit-ready" index.html

                    if grep -q '\\${DAY40' nginx.conf; then
                      echo "Day 40 nginx.conf should not contain unresolved env placeholders."
                      exit 1
                    fi

                    echo "Day 40 frontend files are valid."
                    '''
                }
            }
        }

        stage('Validate Day 40 Env Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 40 dev env file..."
                    grep "DAY40_APP_ENV=day40-dev-env" .env
                    grep "DAY40_DEPLOY_TARGET=dev" .env
                    grep "DAY40_APP_VERSION=day40-dev-v1" .env
                    grep "DAY40_FEATURE_FLAG=enabled" .env
                    grep "DAY40_FRONTEND_PORT=8040" .env

                    echo "Validating Day 40 staging env file..."
                    grep "DAY40_APP_ENV=day40-staging-env" .env.staging
                    grep "DAY40_DEPLOY_TARGET=staging" .env.staging
                    grep "DAY40_APP_VERSION=day40-staging-v1" .env.staging
                    grep "DAY40_FEATURE_FLAG=enabled" .env.staging
                    grep "DAY40_FRONTEND_PORT=8140" .env.staging

                    echo "Validating Day 40 prodlike env file..."
                    grep "DAY40_APP_ENV=day40-prodlike-env" .env.prodlike
                    grep "DAY40_DEPLOY_TARGET=prodlike" .env.prodlike
                    grep "DAY40_APP_VERSION=day40-prodlike-v1" .env.prodlike
                    grep "DAY40_FEATURE_FLAG=disabled" .env.prodlike
                    grep "DAY40_FRONTEND_PORT=8240" .env.prodlike

                    echo "Day 40 env file value validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 40 Selected Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating selected Day 40 runtime env file: $RUNTIME_ENV_FILE"

                    grep "DAY40_APP_ENV=$EXPECTED_APP_ENV" "$RUNTIME_ENV_FILE"
                    grep "DAY40_DEPLOY_TARGET=$EXPECTED_DEPLOY_TARGET" "$RUNTIME_ENV_FILE"
                    grep "DAY40_APP_VERSION=$EXPECTED_APP_VERSION" "$RUNTIME_ENV_FILE"
                    grep "DAY40_FEATURE_FLAG=$EXPECTED_FEATURE_FLAG" "$RUNTIME_ENV_FILE"
                    grep "DAY40_FRONTEND_PORT=$EXPECTED_FRONTEND_PORT" "$RUNTIME_ENV_FILE"
                    grep "DAY40_BUILD_NUMBER=$EXPECTED_BUILD_NUMBER" "$RUNTIME_ENV_FILE"
                    grep "DAY40_GIT_COMMIT=$EXPECTED_GIT_COMMIT" "$RUNTIME_ENV_FILE"
                    grep "DAY40_IMAGE_TAG=$EXPECTED_IMAGE_TAG" "$RUNTIME_ENV_FILE"
                    grep "DAY40_RELEASE_CREATED_AT=$EXPECTED_RELEASE_CREATED_AT" "$RUNTIME_ENV_FILE"

                    echo "Selected Day 40 runtime env file matches DEPLOY_ENV=$DEPLOY_ENV."
                    '''
                }
            }
        }

        stage('Validate Day 40 Env Key Drift') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Checking Day 40 env key drift..."

                    cut -d '=' -f 1 .env | grep -v '^$' | sort > day40-env-keys.txt
                    cut -d '=' -f 1 .env.staging | grep -v '^$' | sort > day40-staging-env-keys.txt
                    cut -d '=' -f 1 .env.prodlike | grep -v '^$' | sort > day40-prodlike-env-keys.txt
                    cut -d '=' -f 1 .env.example | grep -v '^$' | sort > day40-env-example-keys.txt

                    diff -u day40-env-example-keys.txt day40-env-keys.txt
                    diff -u day40-env-example-keys.txt day40-staging-env-keys.txt
                    diff -u day40-env-example-keys.txt day40-prodlike-env-keys.txt

                    rm -f day40-env-keys.txt day40-staging-env-keys.txt day40-prodlike-env-keys.txt day40-env-example-keys.txt

                    echo "Day 40 env files contain the same keys."
                    '''
                }
            }
        }

        stage('Validate Day 40 Audit Code') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 40 audit-related code..."

                    grep "app.get('/api/audit-ready'" backend/app.js
                    grep "auditReady" backend/app.js
                    grep "deployment-audit" Jenkinsfile
                    grep "day40-deployment-audit.json" Jenkinsfile
                    grep "day40-deployment-audit.txt" Jenkinsfile
                    grep "releaseManifestMatchesRuntime" backend/app.js

                    echo "Day 40 audit code validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 40 Release Manifest Code') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 40 release manifest code..."

                    grep "release.json" backend/Dockerfile
                    grep "DAY40_RELEASE_CREATED_AT" backend/Dockerfile
                    grep "readReleaseManifest" backend/app.js
                    grep "releaseManifestMatchesRuntime" backend/app.js
                    grep "app.get('/api/release'" backend/app.js
                    grep "RELEASE_CREATED_AT" backend/app.js

                    echo "Day 40 release manifest code validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 40 Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 40 Docker Compose config..."

                    grep "condition: service_healthy" docker-compose.yml
                    grep "healthcheck:" docker-compose.yml
                    grep "day40-backend:" docker-compose.yml
                    grep "day40-backend:\\${DAY40_IMAGE_TAG}" docker-compose.yml
                    grep "day40-frontend:\\${DAY40_IMAGE_TAG}" docker-compose.yml
                    grep "DAY40_RELEASE_CREATED_AT" docker-compose.yml
                    grep "args:" docker-compose.yml
                    grep "http://127.0.0.1:3000/health" docker-compose.yml

                    if grep -q "broken-health" docker-compose.yml; then
                      echo "Day 40 docker-compose.yml contains broken-health."
                      exit 1
                    fi

                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_APP_ENV"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_DEPLOY_TARGET"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_IMAGE_TAG"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_RELEASE_CREATED_AT"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "http://127.0.0.1:3000/health"

                    echo "Day 40 Compose validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 40 App Fails Without Required Env') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Testing that Day 40 backend fails fast without required environment variables..."

                    set +e
                    env -u PORT \
    -u APP_ENV \
    -u APP_VERSION \
    -u SERVICE_NAME \
    -u FEATURE_FLAG \
    -u LOG_LEVEL \
    -u METRICS_ENABLED \
    -u DEPLOY_TARGET \
    -u BUILD_NUMBER \
    -u GIT_COMMIT \
    -u IMAGE_TAG \
    node app.js > day40-missing-env.log 2>&1
                    EXIT_CODE=$?
                    set -e

                    cat day40-missing-env.log

                    if [ "$EXIT_CODE" -eq 0 ]; then
                      echo "Day 40 backend unexpectedly started without required environment variables."
                      rm -f day40-missing-env.log
                      exit 1
                    fi

                    grep "Missing required environment variables" day40-missing-env.log
                    grep "BUILD_NUMBER" day40-missing-env.log
                    grep "GIT_COMMIT" day40-missing-env.log
                    grep "IMAGE_TAG" day40-missing-env.log
                    grep "RELEASE_CREATED_AT" day40-missing-env.log

                    rm -f day40-missing-env.log

                    echo "Day 40 backend correctly fails when required environment variables are missing."
                    '''
                }
            }
        }

        stage('Render Day 40 Docker Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Rendering Day 40 Docker Compose config with runtime env file: $RUNTIME_ENV_FILE"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config

                    echo "Day 40 Docker Compose config rendered successfully."
                    '''
                }
            }
        }

        stage('Build Day 40 Docker Images') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Building Day 40 Docker images with tag: $EXPECTED_IMAGE_TAG"
                    docker compose --env-file "$RUNTIME_ENV_FILE" build --no-cache

                    echo "Inspecting release manifest inside built backend image..."
                    docker run --rm "day40-backend:$EXPECTED_IMAGE_TAG" cat /app/release.json | tee day40-release-from-image.json

                    grep "\\"service\\": \\"day40-backend\\"" day40-release-from-image.json
                    grep "\\"deployTarget\\": \\"$EXPECTED_DEPLOY_TARGET\\"" day40-release-from-image.json
                    grep "\\"appVersion\\": \\"$EXPECTED_APP_VERSION\\"" day40-release-from-image.json
                    grep "\\"buildNumber\\": \\"$EXPECTED_BUILD_NUMBER\\"" day40-release-from-image.json
                    grep "\\"gitCommit\\": \\"$EXPECTED_GIT_COMMIT\\"" day40-release-from-image.json
                    grep "\\"imageTag\\": \\"$EXPECTED_IMAGE_TAG\\"" day40-release-from-image.json
                    grep "\\"releaseCreatedAt\\": \\"$EXPECTED_RELEASE_CREATED_AT\\"" day40-release-from-image.json

                    rm -f day40-release-from-image.json

                    echo "Day 40 Docker images built and release manifest verified successfully."
                    '''
                }
            }
        }

        stage('Deploy Day 40 With Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Stopping old Day 40 containers if they exist..."
                    docker compose --env-file "$RUNTIME_ENV_FILE" down || true

                    echo "Starting Day 40 application using runtime env file: $RUNTIME_ENV_FILE"
                    docker compose --env-file "$RUNTIME_ENV_FILE" up -d

                    echo "Current Day 40 containers:"
                    docker ps --filter "name=day40_"
                    '''
                }
            }
        }

        stage('Verify Day 40 Frontend Waited for Backend Health') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    BACKEND_HEALTH=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                    FRONTEND_RUNNING=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}' 2>/dev/null || echo "unknown")

                    echo "Day 40 backend health: $BACKEND_HEALTH"
                    echo "Day 40 frontend running: $FRONTEND_RUNNING"

                    if [ "$BACKEND_HEALTH" != "healthy" ]; then
                      docker logs --tail=50 "$BACKEND_CONTAINER" || true
                      exit 1
                    fi

                    if [ "$FRONTEND_RUNNING" != "true" ]; then
                      docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                      exit 1
                    fi

                    echo "Day 40 frontend is running after backend became healthy."
                    '''
                }
            }
        }

        stage('Smoke Test Day 40 Backend Health') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-health-smoke' http://127.0.0.1:3000/health")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"status":"ok"'
                echo "$RESPONSE" | grep '"service":"day40-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"version\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$RESPONSE" | grep '"releaseManifestMatchesRuntime":true'
                echo "$RESPONSE" | grep "\\"buildNumber\\":\\"$EXPECTED_BUILD_NUMBER\\""
                echo "$RESPONSE" | grep "\\"gitCommit\\":\\"$EXPECTED_GIT_COMMIT\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""
                echo "$RESPONSE" | grep "\\"releaseCreatedAt\\":\\"$EXPECTED_RELEASE_CREATED_AT\\""

                echo "Day 40 backend health smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 40 Version Endpoint') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-version-smoke' http://127.0.0.1:3000/api/version")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day40-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"appVersion\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$RESPONSE" | grep "\\"buildNumber\\":\\"$EXPECTED_BUILD_NUMBER\\""
                echo "$RESPONSE" | grep "\\"gitCommit\\":\\"$EXPECTED_GIT_COMMIT\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""
                echo "$RESPONSE" | grep "\\"releaseCreatedAt\\":\\"$EXPECTED_RELEASE_CREATED_AT\\""

                echo "Day 40 version endpoint smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 40 Release Endpoint') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-release-smoke' http://127.0.0.1:3000/api/release")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"service":"day40-backend"'
                echo "$RESPONSE" | grep '"runtimeMetadata"'
                echo "$RESPONSE" | grep '"imageReleaseManifest"'
                echo "$RESPONSE" | grep '"releaseManifestMatchesRuntime":true'
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"buildNumber\\":\\"$EXPECTED_BUILD_NUMBER\\""
                echo "$RESPONSE" | grep "\\"gitCommit\\":\\"$EXPECTED_GIT_COMMIT\\""
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""
                echo "$RESPONSE" | grep "\\"releaseCreatedAt\\":\\"$EXPECTED_RELEASE_CREATED_AT\\""

                echo "Day 40 release endpoint smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 40 Audit Ready Endpoint') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-audit-ready-smoke' http://127.0.0.1:3000/api/audit-ready")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"auditReady":true'
                echo "$RESPONSE" | grep '"service":"day40-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep '"releaseManifestMatchesRuntime":true'
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 40 audit readiness smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 40 Backend API and Config') {
            steps {
                sh '''
                set -e

                API_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-api-smoke' http://127.0.0.1:3000/api/message")
                CONFIG_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-config-smoke' http://127.0.0.1:3000/api/config")

                echo "$API_RESPONSE"
                echo "$CONFIG_RESPONSE"

                echo "$API_RESPONSE" | grep 'Hello from Day 40 backend API'
                echo "$API_RESPONSE" | grep "\\"featureFlag\\":\\"$EXPECTED_FEATURE_FLAG\\""
                echo "$API_RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "$CONFIG_RESPONSE" | grep '"service":"day40-backend"'
                echo "$CONFIG_RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$CONFIG_RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$CONFIG_RESPONSE" | grep "\\"version\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$CONFIG_RESPONSE" | grep "\\"featureFlag\\":\\"$EXPECTED_FEATURE_FLAG\\""
                echo "$CONFIG_RESPONSE" | grep '"metricsEnabled":true'
                echo "$CONFIG_RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 40 backend API and config smoke tests passed."
                '''
            }
        }

        stage('Smoke Test Day 40 Controlled Error and Metrics') {
            steps {
                sh '''
                set -e

                set +e
                docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-error-smoke' http://127.0.0.1:3000/api/error-test"
                ERROR_EXIT_CODE=$?
                set -e

                if [ "$ERROR_EXIT_CODE" -eq 0 ]; then
                  echo "Day 40 error-test unexpectedly returned success."
                  exit 1
                fi

                METRICS_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-metrics-smoke' http://127.0.0.1:3000/metrics")

                echo "$METRICS_RESPONSE"

                echo "$METRICS_RESPONSE" | grep '"service":"day40-backend"'
                echo "$METRICS_RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$METRICS_RESPONSE" | grep '"metricsEnabled":true'
                echo "$METRICS_RESPONSE" | grep '"totalRequests"'
                echo "$METRICS_RESPONSE" | grep '"requestsByPath"'
                echo "$METRICS_RESPONSE" | grep '"statusCodes"'
                echo "$METRICS_RESPONSE" | grep '"/api/version"'
                echo "$METRICS_RESPONSE" | grep '"/api/release"'
                echo "$METRICS_RESPONSE" | grep '"/api/audit-ready"'
                echo "$METRICS_RESPONSE" | grep '"/api/error-test"'
                echo "$METRICS_RESPONSE" | grep '"200"'
                echo "$METRICS_RESPONSE" | grep '"500"'

                echo "Day 40 controlled error and metrics smoke tests passed."
                '''
            }
        }

        stage('Smoke Test Day 40 Frontend') {
            steps {
                sh '''
                set -e

                PAGE_RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/")
                RELEASE_PROXY_RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-proxy-release-smoke' http://127.0.0.1/api/release")

                echo "$PAGE_RESPONSE"
                echo "$RELEASE_PROXY_RESPONSE"

                echo "$PAGE_RESPONSE" | grep 'DevOps Day 40'
                echo "$PAGE_RESPONSE" | grep 'deployment audit report'
                echo "$PAGE_RESPONSE" | grep 'Backend Audit Readiness'

                echo "$RELEASE_PROXY_RESPONSE" | grep '"service":"day40-backend"'
                echo "$RELEASE_PROXY_RESPONSE" | grep '"releaseManifestMatchesRuntime":true'
                echo "$RELEASE_PROXY_RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 40 frontend smoke tests passed."
                '''
            }
        }

        stage('Verify Day 40 Container Image and Manifest') {
            steps {
                sh '''
                set -e

                BACKEND_IMAGE=$(docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}')
                FRONTEND_IMAGE=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}')

                echo "Day 40 backend image: $BACKEND_IMAGE"
                echo "Day 40 frontend image: $FRONTEND_IMAGE"

                echo "$BACKEND_IMAGE" | grep "day40-backend:$EXPECTED_IMAGE_TAG"
                echo "$FRONTEND_IMAGE" | grep "day40-frontend:$EXPECTED_IMAGE_TAG"

                docker exec "$BACKEND_CONTAINER" cat /app/release.json | tee day40-running-release.json

                grep "\\"deployTarget\\": \\"$EXPECTED_DEPLOY_TARGET\\"" day40-running-release.json
                grep "\\"appVersion\\": \\"$EXPECTED_APP_VERSION\\"" day40-running-release.json
                grep "\\"buildNumber\\": \\"$EXPECTED_BUILD_NUMBER\\"" day40-running-release.json
                grep "\\"gitCommit\\": \\"$EXPECTED_GIT_COMMIT\\"" day40-running-release.json
                grep "\\"imageTag\\": \\"$EXPECTED_IMAGE_TAG\\"" day40-running-release.json
                grep "\\"releaseCreatedAt\\": \\"$EXPECTED_RELEASE_CREATED_AT\\"" day40-running-release.json

                rm -f day40-running-release.json

                echo "Day 40 running container image and release manifest verified."
                '''
            }
        }

        stage('Verify Day 40 Backend Logs') {
            steps {
                sh '''
                set -e

                LOGS=$(docker logs "$BACKEND_CONTAINER" 2>&1)

                echo "$LOGS" | grep 'request_completed'
                echo "$LOGS" | grep 'day40-api-smoke'
                echo "$LOGS" | grep 'day40-config-smoke'
                echo "$LOGS" | grep 'day40-version-smoke'
                echo "$LOGS" | grep 'day40-release-smoke'
                echo "$LOGS" | grep 'day40-audit-ready-smoke'
                echo "$LOGS" | grep 'controlled_error_test_triggered'
                echo "$LOGS" | grep '"statusCode":200'
                echo "$LOGS" | grep '"statusCode":500'
                echo "$LOGS" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$LOGS" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""
                echo "$LOGS" | grep "\\"releaseCreatedAt\\":\\"$EXPECTED_RELEASE_CREATED_AT\\""

                echo "Day 40 backend logs contain request IDs, release metadata, image tag, and error evidence."
                '''
            }
        }

        stage('Write Day 40 Deployment Audit Report') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    mkdir -p "$AUDIT_DIR"

                    AUDIT_CREATED_AT=$(date -u +%Y-%m-%dT%H-%M-%SZ)
                    BACKEND_IMAGE=$(docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}')
                    FRONTEND_IMAGE=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}')
                    BACKEND_HEALTH=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}')
                    FRONTEND_RUNNING=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}')

                    VERSION_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-audit-version' http://127.0.0.1:3000/api/version")
                    RELEASE_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-audit-release' http://127.0.0.1:3000/api/release")
                    AUDIT_READY_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day40-audit-ready' http://127.0.0.1:3000/api/audit-ready")

                    cat > "$AUDIT_JSON" <<EOF
{
  "day": "Day 40",
  "auditCreatedAt": "$AUDIT_CREATED_AT",
  "jenkinsBuildNumber": "$EXPECTED_BUILD_NUMBER",
  "deployEnvParameter": "$DEPLOY_ENV",
  "baseEnvFile": "$BASE_ENV_FILE",
  "runtimeEnvFile": "$RUNTIME_ENV_FILE",
  "expected": {
    "appEnvironment": "$EXPECTED_APP_ENV",
    "deployTarget": "$EXPECTED_DEPLOY_TARGET",
    "appVersion": "$EXPECTED_APP_VERSION",
    "featureFlag": "$EXPECTED_FEATURE_FLAG",
    "gitCommit": "$EXPECTED_GIT_COMMIT",
    "imageTag": "$EXPECTED_IMAGE_TAG",
    "releaseCreatedAt": "$EXPECTED_RELEASE_CREATED_AT"
  },
  "containers": {
    "backendContainer": "$BACKEND_CONTAINER",
    "frontendContainer": "$FRONTEND_CONTAINER",
    "backendImage": "$BACKEND_IMAGE",
    "frontendImage": "$FRONTEND_IMAGE",
    "backendHealth": "$BACKEND_HEALTH",
    "frontendRunning": "$FRONTEND_RUNNING"
  },
  "verification": {
    "backendHealthPassed": true,
    "releaseManifestMatchesRuntime": true,
    "versionEndpointPassed": true,
    "releaseEndpointPassed": true,
    "auditReadyEndpointPassed": true,
    "frontendProxyPassed": true,
    "metricsPassed": true,
    "logsPassed": true
  }
}
EOF

                    cat > "$AUDIT_TEXT" <<EOF
Day 40 Deployment Audit Report
==============================

Audit created at: $AUDIT_CREATED_AT
Jenkins build number: $EXPECTED_BUILD_NUMBER
Deploy environment parameter: $DEPLOY_ENV
Base env file: $BASE_ENV_FILE
Runtime env file: $RUNTIME_ENV_FILE

Expected app environment: $EXPECTED_APP_ENV
Expected deploy target: $EXPECTED_DEPLOY_TARGET
Expected app version: $EXPECTED_APP_VERSION
Expected feature flag: $EXPECTED_FEATURE_FLAG
Expected git commit: $EXPECTED_GIT_COMMIT
Expected image tag: $EXPECTED_IMAGE_TAG
Expected release created at: $EXPECTED_RELEASE_CREATED_AT

Backend container: $BACKEND_CONTAINER
Frontend container: $FRONTEND_CONTAINER
Backend image: $BACKEND_IMAGE
Frontend image: $FRONTEND_IMAGE
Backend health: $BACKEND_HEALTH
Frontend running: $FRONTEND_RUNNING

Smoke test status:
- Backend health: passed
- Version endpoint: passed
- Release endpoint: passed
- Audit-ready endpoint: passed
- Runtime config: passed
- Metrics: passed
- Frontend proxy: passed
- Backend logs: passed

Version endpoint response:
$VERSION_RESPONSE

Release endpoint response:
$RELEASE_RESPONSE

Audit-ready endpoint response:
$AUDIT_READY_RESPONSE
EOF

                    echo "Day 40 deployment audit JSON:"
                    cat "$AUDIT_JSON"

                    echo "Day 40 deployment audit text:"
                    cat "$AUDIT_TEXT"

                    grep "\\"day\\": \\"Day 40\\"" "$AUDIT_JSON"
                    grep "\\"deployEnvParameter\\": \\"$DEPLOY_ENV\\"" "$AUDIT_JSON"
                    grep "\\"imageTag\\": \\"$EXPECTED_IMAGE_TAG\\"" "$AUDIT_JSON"
                    grep "\\"backendHealth\\": \\"healthy\\"" "$AUDIT_JSON"
                    grep "\\"frontendRunning\\": \\"true\\"" "$AUDIT_JSON"
                    grep "\\"releaseManifestMatchesRuntime\\": true" "$AUDIT_JSON"

                    grep "Day 40 Deployment Audit Report" "$AUDIT_TEXT"
                    grep "$EXPECTED_IMAGE_TAG" "$AUDIT_TEXT"
                    grep "$EXPECTED_GIT_COMMIT" "$AUDIT_TEXT"

                    echo "Day 40 deployment audit report written and validated."
                    '''
                }
            }
        }

        stage('Show Day 40 Deployment Diagnostics') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Day 40 selected DEPLOY_ENV: $DEPLOY_ENV"
                    echo "Day 40 base env file: $BASE_ENV_FILE"
                    echo "Day 40 runtime env file: $RUNTIME_ENV_FILE"
                    echo "Day 40 expected image tag: $EXPECTED_IMAGE_TAG"
                    echo "Day 40 audit files:"
                    ls -la "$AUDIT_DIR"

                    echo "Day 40 Docker Compose service status:"
                    docker compose --env-file "$RUNTIME_ENV_FILE" ps

                    echo "Day 40 containers:"
                    docker ps -a --filter "name=day40_"

                    echo "Day 40 backend image:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true

                    echo "Day 40 frontend image:"
                    docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}' || true

                    echo "Day 40 backend release manifest:"
                    docker exec "$BACKEND_CONTAINER" cat /app/release.json || true

                    echo "Day 40 backend health status:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                    echo "Recent Day 40 backend logs:"
                    docker logs --tail=120 "$BACKEND_CONTAINER" || true

                    echo "Recent Day 40 frontend logs:"
                    docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Day 40 pipeline completed successfully. Deployment audit report was generated.'
        }

        failure {
            echo 'Day 40 pipeline failed. Collecting failure diagnostics...'
        }

        always {
            dir("${PROJECT_DIR}") {
                sh '''
                echo "Final Day 40 selected DEPLOY_ENV:"
                echo "$DEPLOY_ENV"

                echo "Final Day 40 runtime env file:"
                echo "$RUNTIME_ENV_FILE"

                echo "Final Day 40 audit files:"
                ls -la "$AUDIT_DIR" || true

                echo "Final Day 40 Docker Compose status:"
                docker compose --env-file "$RUNTIME_ENV_FILE" ps || true

                echo "Final Day 40 container list:"
                docker ps -a --filter "name=day40_" || true

                echo "Final Day 40 backend image:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true

                echo "Final Day 40 frontend image:"
                docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}' || true

                echo "Final Day 40 backend release manifest:"
                docker exec "$BACKEND_CONTAINER" cat /app/release.json || true

                echo "Final Day 40 backend health:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                echo "Final Day 40 backend logs:"
                docker logs --tail=120 "$BACKEND_CONTAINER" || true

                echo "Final Day 40 frontend logs:"
                docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                '''
            }
        }
    }
}
