pipeline {
    agent any

    parameters {
        choice(
            name: 'DEPLOY_ENV',
            choices: ['staging', 'dev', 'prodlike'],
            description: 'Choose which Day 41 environment Jenkins should deploy.'
        )
    }

    environment {
        DAY_NAME = 'Day 41'
        PROJECT_DIR = 'devops-day41'
        RUNTIME_ENV_FILE = '.env.runtime'
        BACKEND_CONTAINER = 'day41_backend'
        FRONTEND_CONTAINER = 'day41_frontend'
        AUDIT_DIR = 'deployment-audit'
        AUDIT_JSON = 'deployment-audit/day41-deployment-audit.json'
        AUDIT_TEXT = 'deployment-audit/day41-deployment-audit.txt'
        CHECKSUM_FILE = 'deployment-audit/day41-evidence-checksums.txt'
        EVIDENCE_BUNDLE = 'deployment-audit/day41-evidence-bundle.tar.gz'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code for Day 41...'
                checkout scm
            }
        }

        stage('Select Day 41 Environment File') {
            steps {
                script {
                    if (params.DEPLOY_ENV == 'dev') {
                        env.BASE_ENV_FILE = '.env'
                        env.EXPECTED_APP_ENV = 'day41-dev-env'
                        env.EXPECTED_DEPLOY_TARGET = 'dev'
                        env.EXPECTED_APP_VERSION = 'day41-dev-v1'
                        env.EXPECTED_FEATURE_FLAG = 'enabled'
                        env.EXPECTED_FRONTEND_PORT = '8041'
                    } else if (params.DEPLOY_ENV == 'staging') {
                        env.BASE_ENV_FILE = '.env.staging'
                        env.EXPECTED_APP_ENV = 'day41-staging-env'
                        env.EXPECTED_DEPLOY_TARGET = 'staging'
                        env.EXPECTED_APP_VERSION = 'day41-staging-v1'
                        env.EXPECTED_FEATURE_FLAG = 'enabled'
                        env.EXPECTED_FRONTEND_PORT = '8141'
                    } else if (params.DEPLOY_ENV == 'prodlike') {
                        env.BASE_ENV_FILE = '.env.prodlike'
                        env.EXPECTED_APP_ENV = 'day41-prodlike-env'
                        env.EXPECTED_DEPLOY_TARGET = 'prodlike'
                        env.EXPECTED_APP_VERSION = 'day41-prodlike-v1'
                        env.EXPECTED_FEATURE_FLAG = 'disabled'
                        env.EXPECTED_FRONTEND_PORT = '8241'
                    } else {
                        error "Unsupported Day 41 DEPLOY_ENV: ${params.DEPLOY_ENV}"
                    }

                    echo "Day 41 selected DEPLOY_ENV=${params.DEPLOY_ENV}"
                    echo "Day 41 selected BASE_ENV_FILE=${env.BASE_ENV_FILE}"
                }
            }
        }

        stage('Validate Day 41 Jenkins Runtime') {
            steps {
                sh '''
                set -e

                echo "Validating Day 41 Jenkins runtime tools..."

                git --version
                node --version
                npm --version
                docker --version
                docker compose version
                sha256sum --version | head -1
                tar --version | head -1

                echo "Day 41 Jenkins runtime has required tools."
                '''
            }
        }

        stage('Validate Day 41 Project Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 41 required project files..."

                    REQUIRED_FILES="
backend/app.js
backend/package.json
backend/Dockerfile
backend/.dockerignore
frontend/index.html
frontend/nginx.conf
frontend/Dockerfile
frontend/.dockerignore
deployment-audit/.gitkeep
.env
.env.staging
.env.prodlike
.env.example
docker-compose.yml
Jenkinsfile
README.md
"

                    for file in $REQUIRED_FILES; do
                      if [ ! -f "$file" ]; then
                        echo "Missing required Day 41 file: $file"
                        echo "Current Day 41 files:"
                        find . -maxdepth 3 -type f | sort
                        exit 1
                      fi

                      echo "Found Day 41 file: $file"
                    done

                    echo "All Day 41 required files found."
                    '''
                }
            }
        }

        stage('Generate Day 41 Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Generating Day 41 runtime env file from $BASE_ENV_FILE..."

                    GIT_COMMIT_SHORT=$(git rev-parse --short HEAD)
                    BUILD_NUMBER_VALUE="${BUILD_NUMBER:-local}"
                    RELEASE_CREATED_AT=$(date -u +%Y-%m-%dT%H-%M-%SZ)
                    IMAGE_TAG="day41-${DEPLOY_ENV}-${BUILD_NUMBER_VALUE}-${GIT_COMMIT_SHORT}"

                    grep -v '^DAY41_BUILD_NUMBER=' "$BASE_ENV_FILE" \
                      | grep -v '^DAY41_GIT_COMMIT=' \
                      | grep -v '^DAY41_IMAGE_TAG=' \
                      | grep -v '^DAY41_RELEASE_CREATED_AT=' > "$RUNTIME_ENV_FILE"

                    {
                      echo "DAY41_BUILD_NUMBER=$BUILD_NUMBER_VALUE"
                      echo "DAY41_GIT_COMMIT=$GIT_COMMIT_SHORT"
                      echo "DAY41_IMAGE_TAG=$IMAGE_TAG"
                      echo "DAY41_RELEASE_CREATED_AT=$RELEASE_CREATED_AT"
                    } >> "$RUNTIME_ENV_FILE"

                    echo "Day 41 runtime env file:"
                    cat "$RUNTIME_ENV_FILE"

                    echo "DAY41_EXPECTED_BUILD_NUMBER=$BUILD_NUMBER_VALUE" > day41-build-metadata.env
                    echo "DAY41_EXPECTED_GIT_COMMIT=$GIT_COMMIT_SHORT" >> day41-build-metadata.env
                    echo "DAY41_EXPECTED_IMAGE_TAG=$IMAGE_TAG" >> day41-build-metadata.env
                    echo "DAY41_EXPECTED_RELEASE_CREATED_AT=$RELEASE_CREATED_AT" >> day41-build-metadata.env
                    '''
                }
            }
        }

        stage('Load Day 41 Build Metadata') {
            steps {
                dir("${PROJECT_DIR}") {
                    script {
                        env.EXPECTED_BUILD_NUMBER = sh(
                            returnStdout: true,
                            script: ". ./day41-build-metadata.env && echo \$DAY41_EXPECTED_BUILD_NUMBER"
                        ).trim()

                        env.EXPECTED_GIT_COMMIT = sh(
                            returnStdout: true,
                            script: ". ./day41-build-metadata.env && echo \$DAY41_EXPECTED_GIT_COMMIT"
                        ).trim()

                        env.EXPECTED_IMAGE_TAG = sh(
                            returnStdout: true,
                            script: ". ./day41-build-metadata.env && echo \$DAY41_EXPECTED_IMAGE_TAG"
                        ).trim()

                        env.EXPECTED_RELEASE_CREATED_AT = sh(
                            returnStdout: true,
                            script: ". ./day41-build-metadata.env && echo \$DAY41_EXPECTED_RELEASE_CREATED_AT"
                        ).trim()

                        echo "Day 41 expected build number: ${env.EXPECTED_BUILD_NUMBER}"
                        echo "Day 41 expected git commit: ${env.EXPECTED_GIT_COMMIT}"
                        echo "Day 41 expected image tag: ${env.EXPECTED_IMAGE_TAG}"
                        echo "Day 41 expected release created at: ${env.EXPECTED_RELEASE_CREATED_AT}"
                    }
                }
            }
        }

        stage('Validate Day 41 Backend Syntax') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Validating Day 41 backend JavaScript syntax..."
                    node --check app.js

                    echo "Day 41 backend syntax is valid."
                    '''
                }
            }
        }

        stage('Validate Day 41 Frontend Files') {
            steps {
                dir("${PROJECT_DIR}/frontend") {
                    sh '''
                    set -e

                    echo "Validating Day 41 frontend files..."

                    test -s index.html
                    test -s nginx.conf

                    grep "DevOps Day 41" index.html
                    grep "day41-backend" nginx.conf
                    grep "X-Request-Id" nginx.conf
                    grep "/metrics" nginx.conf
                    grep "/api/version" index.html
                    grep "/api/release" index.html
                    grep "/api/audit-ready" index.html
                    grep "/api/evidence-ready" index.html

                    if grep -q '\\${DAY41' nginx.conf; then
                      echo "Day 41 nginx.conf should not contain unresolved env placeholders."
                      exit 1
                    fi

                    echo "Day 41 frontend files are valid."
                    '''
                }
            }
        }

        stage('Validate Day 41 Env Files') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 41 dev env file..."
                    grep "DAY41_APP_ENV=day41-dev-env" .env
                    grep "DAY41_DEPLOY_TARGET=dev" .env
                    grep "DAY41_APP_VERSION=day41-dev-v1" .env
                    grep "DAY41_FEATURE_FLAG=enabled" .env
                    grep "DAY41_FRONTEND_PORT=8041" .env

                    echo "Validating Day 41 staging env file..."
                    grep "DAY41_APP_ENV=day41-staging-env" .env.staging
                    grep "DAY41_DEPLOY_TARGET=staging" .env.staging
                    grep "DAY41_APP_VERSION=day41-staging-v1" .env.staging
                    grep "DAY41_FEATURE_FLAG=enabled" .env.staging
                    grep "DAY41_FRONTEND_PORT=8141" .env.staging

                    echo "Validating Day 41 prodlike env file..."
                    grep "DAY41_APP_ENV=day41-prodlike-env" .env.prodlike
                    grep "DAY41_DEPLOY_TARGET=prodlike" .env.prodlike
                    grep "DAY41_APP_VERSION=day41-prodlike-v1" .env.prodlike
                    grep "DAY41_FEATURE_FLAG=disabled" .env.prodlike
                    grep "DAY41_FRONTEND_PORT=8241" .env.prodlike

                    echo "Day 41 env file value validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 41 Selected Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating selected Day 41 runtime env file: $RUNTIME_ENV_FILE"

                    grep "DAY41_APP_ENV=$EXPECTED_APP_ENV" "$RUNTIME_ENV_FILE"
                    grep "DAY41_DEPLOY_TARGET=$EXPECTED_DEPLOY_TARGET" "$RUNTIME_ENV_FILE"
                    grep "DAY41_APP_VERSION=$EXPECTED_APP_VERSION" "$RUNTIME_ENV_FILE"
                    grep "DAY41_FEATURE_FLAG=$EXPECTED_FEATURE_FLAG" "$RUNTIME_ENV_FILE"
                    grep "DAY41_FRONTEND_PORT=$EXPECTED_FRONTEND_PORT" "$RUNTIME_ENV_FILE"
                    grep "DAY41_BUILD_NUMBER=$EXPECTED_BUILD_NUMBER" "$RUNTIME_ENV_FILE"
                    grep "DAY41_GIT_COMMIT=$EXPECTED_GIT_COMMIT" "$RUNTIME_ENV_FILE"
                    grep "DAY41_IMAGE_TAG=$EXPECTED_IMAGE_TAG" "$RUNTIME_ENV_FILE"
                    grep "DAY41_RELEASE_CREATED_AT=$EXPECTED_RELEASE_CREATED_AT" "$RUNTIME_ENV_FILE"

                    echo "Selected Day 41 runtime env file matches DEPLOY_ENV=$DEPLOY_ENV."
                    '''
                }
            }
        }

        stage('Validate Day 41 Env Key Drift') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Checking Day 41 env key drift..."

                    cut -d '=' -f 1 .env | grep -v '^$' | sort > day41-env-keys.txt
                    cut -d '=' -f 1 .env.staging | grep -v '^$' | sort > day41-staging-env-keys.txt
                    cut -d '=' -f 1 .env.prodlike | grep -v '^$' | sort > day41-prodlike-env-keys.txt
                    cut -d '=' -f 1 .env.example | grep -v '^$' | sort > day41-env-example-keys.txt

                    diff -u day41-env-example-keys.txt day41-env-keys.txt
                    diff -u day41-env-example-keys.txt day41-staging-env-keys.txt
                    diff -u day41-env-example-keys.txt day41-prodlike-env-keys.txt

                    rm -f day41-env-keys.txt day41-staging-env-keys.txt day41-prodlike-env-keys.txt day41-env-example-keys.txt

                    echo "Day 41 env files contain the same keys."
                    '''
                }
            }
        }

        stage('Validate Day 41 Evidence Code') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 41 evidence-related code..."

                    grep "app.get('/api/evidence-ready'" backend/app.js
                    grep "evidenceReady" backend/app.js
                    grep "artifactBundleExpected" backend/app.js
                    grep "checksumExpected" backend/app.js
                    grep "sha256sum" Jenkinsfile
                    grep "day41-evidence-bundle.tar.gz" Jenkinsfile
                    grep "archiveArtifacts" Jenkinsfile

                    echo "Day 41 evidence code validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 41 Release Manifest Code') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 41 release manifest code..."

                    grep "release.json" backend/Dockerfile
                    grep "DAY41_RELEASE_CREATED_AT" backend/Dockerfile
                    grep "readReleaseManifest" backend/app.js
                    grep "releaseManifestMatchesRuntime" backend/app.js
                    grep "app.get('/api/release'" backend/app.js
                    grep "RELEASE_CREATED_AT" backend/app.js

                    echo "Day 41 release manifest code validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 41 Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Validating Day 41 Docker Compose config..."

                    grep "condition: service_healthy" docker-compose.yml
                    grep "healthcheck:" docker-compose.yml
                    grep "day41-backend:" docker-compose.yml
                    grep "day41-backend:\\${DAY41_IMAGE_TAG}" docker-compose.yml
                    grep "day41-frontend:\\${DAY41_IMAGE_TAG}" docker-compose.yml
                    grep "DAY41_RELEASE_CREATED_AT" docker-compose.yml
                    grep "args:" docker-compose.yml
                    grep "http://127.0.0.1:3000/health" docker-compose.yml

                    if grep -q "broken-health" docker-compose.yml; then
                      echo "Day 41 docker-compose.yml contains broken-health."
                      exit 1
                    fi

                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_APP_ENV"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_DEPLOY_TARGET"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_IMAGE_TAG"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "$EXPECTED_RELEASE_CREATED_AT"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config | grep "http://127.0.0.1:3000/health"

                    echo "Day 41 Compose validation passed."
                    '''
                }
            }
        }

        stage('Validate Day 41 App Fails Without Required Env') {
            steps {
                dir("${PROJECT_DIR}/backend") {
                    sh '''
                    set -e

                    echo "Testing that Day 41 backend fails fast without required environment variables..."

                    set +e
                    env -u PORT \
    -u APP_ENV \
    -u APP_VERSION \
    -u SERVICE_NAME \
    -u FEATURE_FLAG \
    -u LOG_LEVEL \
    -u METRICS_ENABLED \
    -u DEPLOY_TARGET \
    -u BUILD_NUMBER \
    -u GIT_COMMIT \
    -u IMAGE_TAG \
    node app.js > day40-missing-env.log 2>&1
                    EXIT_CODE=$?
                    set -e

                    cat day41-missing-env.log

                    if [ "$EXIT_CODE" -eq 0 ]; then
                      echo "Day 41 backend unexpectedly started without required environment variables."
                      rm -f day41-missing-env.log
                      exit 1
                    fi

                    grep "Missing required environment variables" day41-missing-env.log
                    grep "BUILD_NUMBER" day41-missing-env.log
                    grep "GIT_COMMIT" day41-missing-env.log
                    grep "IMAGE_TAG" day41-missing-env.log
                    grep "RELEASE_CREATED_AT" day41-missing-env.log

                    rm -f day41-missing-env.log

                    echo "Day 41 backend correctly fails when required environment variables are missing."
                    '''
                }
            }
        }

        stage('Render Day 41 Docker Compose Config') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Rendering Day 41 Docker Compose config with runtime env file: $RUNTIME_ENV_FILE"
                    docker compose --env-file "$RUNTIME_ENV_FILE" config

                    echo "Day 41 Docker Compose config rendered successfully."
                    '''
                }
            }
        }

        stage('Build Day 41 Docker Images') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Building Day 41 Docker images with tag: $EXPECTED_IMAGE_TAG"
                    docker compose --env-file "$RUNTIME_ENV_FILE" build --no-cache

                    echo "Inspecting release manifest inside built backend image..."
                    docker run --rm "day41-backend:$EXPECTED_IMAGE_TAG" cat /app/release.json | tee day41-release-from-image.json

                    grep "\\"service\\": \\"day41-backend\\"" day41-release-from-image.json
                    grep "\\"deployTarget\\": \\"$EXPECTED_DEPLOY_TARGET\\"" day41-release-from-image.json
                    grep "\\"appVersion\\": \\"$EXPECTED_APP_VERSION\\"" day41-release-from-image.json
                    grep "\\"buildNumber\\": \\"$EXPECTED_BUILD_NUMBER\\"" day41-release-from-image.json
                    grep "\\"gitCommit\\": \\"$EXPECTED_GIT_COMMIT\\"" day41-release-from-image.json
                    grep "\\"imageTag\\": \\"$EXPECTED_IMAGE_TAG\\"" day41-release-from-image.json
                    grep "\\"releaseCreatedAt\\": \\"$EXPECTED_RELEASE_CREATED_AT\\"" day41-release-from-image.json

                    rm -f day41-release-from-image.json

                    echo "Day 41 Docker images built and release manifest verified successfully."
                    '''
                }
            }
        }

        stage('Deploy Day 41 With Runtime Env File') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Stopping old Day 41 containers if they exist..."
                    docker compose --env-file "$RUNTIME_ENV_FILE" down || true

                    echo "Starting Day 41 application using runtime env file: $RUNTIME_ENV_FILE"
                    docker compose --env-file "$RUNTIME_ENV_FILE" up -d

                    echo "Current Day 41 containers:"
                    docker ps --filter "name=day41_"
                    '''
                }
            }
        }

        stage('Verify Day 41 Frontend Waited for Backend Health') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    BACKEND_HEALTH=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' 2>/dev/null || echo "unknown")
                    FRONTEND_RUNNING=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}' 2>/dev/null || echo "unknown")

                    echo "Day 41 backend health: $BACKEND_HEALTH"
                    echo "Day 41 frontend running: $FRONTEND_RUNNING"

                    if [ "$BACKEND_HEALTH" != "healthy" ]; then
                      docker logs --tail=50 "$BACKEND_CONTAINER" || true
                      exit 1
                    fi

                    if [ "$FRONTEND_RUNNING" != "true" ]; then
                      docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                      exit 1
                    fi

                    echo "Day 41 frontend is running after backend became healthy."
                    '''
                }
            }
        }

        stage('Smoke Test Day 41 Backend Health') {
            steps {
                sh '''
                set -e

                RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-health-smoke' http://127.0.0.1:3000/health")

                echo "$RESPONSE"

                echo "$RESPONSE" | grep '"status":"ok"'
                echo "$RESPONSE" | grep '"service":"day41-backend"'
                echo "$RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$RESPONSE" | grep "\\"version\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$RESPONSE" | grep '"releaseManifestMatchesRuntime":true'
                echo "$RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 41 backend health smoke test passed."
                '''
            }
        }

        stage('Smoke Test Day 41 Version Release and Evidence') {
            steps {
                sh '''
                set -e

                VERSION_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-version-smoke' http://127.0.0.1:3000/api/version")
                RELEASE_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-release-smoke' http://127.0.0.1:3000/api/release")
                EVIDENCE_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-evidence-ready-smoke' http://127.0.0.1:3000/api/evidence-ready")

                echo "$VERSION_RESPONSE"
                echo "$RELEASE_RESPONSE"
                echo "$EVIDENCE_RESPONSE"

                echo "$VERSION_RESPONSE" | grep '"service":"day41-backend"'
                echo "$VERSION_RESPONSE" | grep "\\"appVersion\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$VERSION_RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "$RELEASE_RESPONSE" | grep '"runtimeMetadata"'
                echo "$RELEASE_RESPONSE" | grep '"imageReleaseManifest"'
                echo "$RELEASE_RESPONSE" | grep '"releaseManifestMatchesRuntime":true'
                echo "$RELEASE_RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "$EVIDENCE_RESPONSE" | grep '"evidenceReady":true'
                echo "$EVIDENCE_RESPONSE" | grep '"artifactBundleExpected":true'
                echo "$EVIDENCE_RESPONSE" | grep '"checksumExpected":true'
                echo "$EVIDENCE_RESPONSE" | grep '"releaseManifestMatchesRuntime":true'

                echo "Day 41 version, release, and evidence endpoints passed."
                '''
            }
        }

        stage('Smoke Test Day 41 API Config Metrics and Error') {
            steps {
                sh '''
                set -e

                API_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-api-smoke' http://127.0.0.1:3000/api/message")
                CONFIG_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-config-smoke' http://127.0.0.1:3000/api/config")

                set +e
                docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-error-smoke' http://127.0.0.1:3000/api/error-test"
                ERROR_EXIT_CODE=$?
                set -e

                if [ "$ERROR_EXIT_CODE" -eq 0 ]; then
                  echo "Day 41 error-test unexpectedly returned success."
                  exit 1
                fi

                METRICS_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-metrics-smoke' http://127.0.0.1:3000/metrics")

                echo "$API_RESPONSE"
                echo "$CONFIG_RESPONSE"
                echo "$METRICS_RESPONSE"

                echo "$API_RESPONSE" | grep 'Hello from Day 41 backend API'
                echo "$API_RESPONSE" | grep "\\"featureFlag\\":\\"$EXPECTED_FEATURE_FLAG\\""
                echo "$API_RESPONSE" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "$CONFIG_RESPONSE" | grep '"service":"day41-backend"'
                echo "$CONFIG_RESPONSE" | grep "\\"environment\\":\\"$EXPECTED_APP_ENV\\""
                echo "$CONFIG_RESPONSE" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$CONFIG_RESPONSE" | grep "\\"version\\":\\"$EXPECTED_APP_VERSION\\""
                echo "$CONFIG_RESPONSE" | grep "\\"featureFlag\\":\\"$EXPECTED_FEATURE_FLAG\\""
                echo "$CONFIG_RESPONSE" | grep '"metricsEnabled":true'

                echo "$METRICS_RESPONSE" | grep '"service":"day41-backend"'
                echo "$METRICS_RESPONSE" | grep '"/api/evidence-ready"'
                echo "$METRICS_RESPONSE" | grep '"/api/error-test"'
                echo "$METRICS_RESPONSE" | grep '"200"'
                echo "$METRICS_RESPONSE" | grep '"500"'

                echo "Day 41 API, config, metrics, and error smoke tests passed."
                '''
            }
        }

        stage('Smoke Test Day 41 Frontend') {
            steps {
                sh '''
                set -e

                PAGE_RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/")
                EVIDENCE_PROXY_RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-proxy-evidence-smoke' http://127.0.0.1/api/evidence-ready")

                echo "$PAGE_RESPONSE"
                echo "$EVIDENCE_PROXY_RESPONSE"

                echo "$PAGE_RESPONSE" | grep 'DevOps Day 41'
                echo "$PAGE_RESPONSE" | grep 'checksummed Jenkins artifacts'
                echo "$PAGE_RESPONSE" | grep 'Backend Evidence Readiness'

                echo "$EVIDENCE_PROXY_RESPONSE" | grep '"service":"day41-backend"'
                echo "$EVIDENCE_PROXY_RESPONSE" | grep '"evidenceReady":true'
                echo "$EVIDENCE_PROXY_RESPONSE" | grep '"releaseManifestMatchesRuntime":true'

                echo "Day 41 frontend smoke tests passed."
                '''
            }
        }

        stage('Verify Day 41 Container Image and Manifest') {
            steps {
                sh '''
                set -e

                BACKEND_IMAGE=$(docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}')
                FRONTEND_IMAGE=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}')

                echo "Day 41 backend image: $BACKEND_IMAGE"
                echo "Day 41 frontend image: $FRONTEND_IMAGE"

                echo "$BACKEND_IMAGE" | grep "day41-backend:$EXPECTED_IMAGE_TAG"
                echo "$FRONTEND_IMAGE" | grep "day41-frontend:$EXPECTED_IMAGE_TAG"

                docker exec "$BACKEND_CONTAINER" cat /app/release.json | tee day41-running-release.json

                grep "\\"deployTarget\\": \\"$EXPECTED_DEPLOY_TARGET\\"" day41-running-release.json
                grep "\\"appVersion\\": \\"$EXPECTED_APP_VERSION\\"" day41-running-release.json
                grep "\\"buildNumber\\": \\"$EXPECTED_BUILD_NUMBER\\"" day41-running-release.json
                grep "\\"gitCommit\\": \\"$EXPECTED_GIT_COMMIT\\"" day41-running-release.json
                grep "\\"imageTag\\": \\"$EXPECTED_IMAGE_TAG\\"" day41-running-release.json
                grep "\\"releaseCreatedAt\\": \\"$EXPECTED_RELEASE_CREATED_AT\\"" day41-running-release.json

                rm -f day41-running-release.json

                echo "Day 41 running container image and release manifest verified."
                '''
            }
        }

        stage('Verify Day 41 Backend Logs') {
            steps {
                sh '''
                set -e

                LOGS=$(docker logs "$BACKEND_CONTAINER" 2>&1)

                echo "$LOGS" | grep 'request_completed'
                echo "$LOGS" | grep 'day41-api-smoke'
                echo "$LOGS" | grep 'day41-config-smoke'
                echo "$LOGS" | grep 'day41-version-smoke'
                echo "$LOGS" | grep 'day41-release-smoke'
                echo "$LOGS" | grep 'day41-evidence-ready-smoke'
                echo "$LOGS" | grep 'controlled_error_test_triggered'
                echo "$LOGS" | grep '"statusCode":200'
                echo "$LOGS" | grep '"statusCode":500'
                echo "$LOGS" | grep "\\"deployTarget\\":\\"$EXPECTED_DEPLOY_TARGET\\""
                echo "$LOGS" | grep "\\"imageTag\\":\\"$EXPECTED_IMAGE_TAG\\""

                echo "Day 41 backend logs contain request IDs, release metadata, image tag, and error evidence."
                '''
            }
        }

        stage('Write Day 41 Deployment Audit Report') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    mkdir -p "$AUDIT_DIR"

                    AUDIT_CREATED_AT=$(date -u +%Y-%m-%dT%H-%M-%SZ)
                    BACKEND_IMAGE=$(docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}')
                    FRONTEND_IMAGE=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}')
                    BACKEND_HEALTH=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}')
                    FRONTEND_RUNNING=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}')

                    VERSION_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-audit-version' http://127.0.0.1:3000/api/version")
                    RELEASE_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-audit-release' http://127.0.0.1:3000/api/release")
                    EVIDENCE_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day41-audit-evidence' http://127.0.0.1:3000/api/evidence-ready")

                    cat > "$AUDIT_JSON" <<EOF
{
  "day": "Day 41",
  "auditCreatedAt": "$AUDIT_CREATED_AT",
  "jenkinsBuildNumber": "$EXPECTED_BUILD_NUMBER",
  "deployEnvParameter": "$DEPLOY_ENV",
  "baseEnvFile": "$BASE_ENV_FILE",
  "runtimeEnvFile": "$RUNTIME_ENV_FILE",
  "expected": {
    "appEnvironment": "$EXPECTED_APP_ENV",
    "deployTarget": "$EXPECTED_DEPLOY_TARGET",
    "appVersion": "$EXPECTED_APP_VERSION",
    "featureFlag": "$EXPECTED_FEATURE_FLAG",
    "gitCommit": "$EXPECTED_GIT_COMMIT",
    "imageTag": "$EXPECTED_IMAGE_TAG",
    "releaseCreatedAt": "$EXPECTED_RELEASE_CREATED_AT"
  },
  "containers": {
    "backendContainer": "$BACKEND_CONTAINER",
    "frontendContainer": "$FRONTEND_CONTAINER",
    "backendImage": "$BACKEND_IMAGE",
    "frontendImage": "$FRONTEND_IMAGE",
    "backendHealth": "$BACKEND_HEALTH",
    "frontendRunning": "$FRONTEND_RUNNING"
  },
  "verification": {
    "backendHealthPassed": true,
    "releaseManifestMatchesRuntime": true,
    "versionEndpointPassed": true,
    "releaseEndpointPassed": true,
    "evidenceReadyEndpointPassed": true,
    "frontendProxyPassed": true,
    "metricsPassed": true,
    "logsPassed": true,
    "artifactBundleCreated": false,
    "checksumsCreated": false
  }
}
EOF

                    cat > "$AUDIT_TEXT" <<EOF
Day 41 Deployment Audit Report
==============================

Audit created at: $AUDIT_CREATED_AT
Jenkins build number: $EXPECTED_BUILD_NUMBER
Deploy environment parameter: $DEPLOY_ENV
Base env file: $BASE_ENV_FILE
Runtime env file: $RUNTIME_ENV_FILE

Expected app environment: $EXPECTED_APP_ENV
Expected deploy target: $EXPECTED_DEPLOY_TARGET
Expected app version: $EXPECTED_APP_VERSION
Expected feature flag: $EXPECTED_FEATURE_FLAG
Expected git commit: $EXPECTED_GIT_COMMIT
Expected image tag: $EXPECTED_IMAGE_TAG
Expected release created at: $EXPECTED_RELEASE_CREATED_AT

Backend container: $BACKEND_CONTAINER
Frontend container: $FRONTEND_CONTAINER
Backend image: $BACKEND_IMAGE
Frontend image: $FRONTEND_IMAGE
Backend health: $BACKEND_HEALTH
Frontend running: $FRONTEND_RUNNING

Smoke test status:
- Backend health: passed
- Version endpoint: passed
- Release endpoint: passed
- Evidence-ready endpoint: passed
- Runtime config: passed
- Metrics: passed
- Frontend proxy: passed
- Backend logs: passed

Version endpoint response:
$VERSION_RESPONSE

Release endpoint response:
$RELEASE_RESPONSE

Evidence-ready endpoint response:
$EVIDENCE_RESPONSE
EOF

                    grep "\\"day\\": \\"Day 41\\"" "$AUDIT_JSON"
                    grep "\\"deployEnvParameter\\": \\"$DEPLOY_ENV\\"" "$AUDIT_JSON"
                    grep "\\"imageTag\\": \\"$EXPECTED_IMAGE_TAG\\"" "$AUDIT_JSON"
                    grep "\\"backendHealth\\": \\"healthy\\"" "$AUDIT_JSON"
                    grep "\\"frontendRunning\\": \\"true\\"" "$AUDIT_JSON"
                    grep "\\"releaseManifestMatchesRuntime\\": true" "$AUDIT_JSON"

                    grep "Day 41 Deployment Audit Report" "$AUDIT_TEXT"
                    grep "$EXPECTED_IMAGE_TAG" "$AUDIT_TEXT"
                    grep "$EXPECTED_GIT_COMMIT" "$AUDIT_TEXT"

                    echo "Day 41 deployment audit report written and validated."
                    '''
                }
            }
        }

        stage('Package Day 41 Evidence Bundle') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Packaging Day 41 deployment evidence..."

                    test -f "$AUDIT_JSON"
                    test -f "$AUDIT_TEXT"

                    docker exec "$BACKEND_CONTAINER" cat /app/release.json > "$AUDIT_DIR/day41-running-release.json"
                    docker inspect "$BACKEND_CONTAINER" > "$AUDIT_DIR/day41-backend-container-inspect.json"
                    docker inspect "$FRONTEND_CONTAINER" > "$AUDIT_DIR/day41-frontend-container-inspect.json"

                    {
                      echo "Day 41 Evidence Bundle Contents"
                      echo "==============================="
                      echo "Created from Jenkins build: $EXPECTED_BUILD_NUMBER"
                      echo "Deploy env: $DEPLOY_ENV"
                      echo "Git commit: $EXPECTED_GIT_COMMIT"
                      echo "Image tag: $EXPECTED_IMAGE_TAG"
                      echo "Release created at: $EXPECTED_RELEASE_CREATED_AT"
                      echo ""
                      echo "Included files:"
                      find "$AUDIT_DIR" -maxdepth 1 -type f | sort
                    } > "$AUDIT_DIR/day41-evidence-summary.txt"

                    sha256sum \
                      "$AUDIT_JSON" \
                      "$AUDIT_TEXT" \
                      "$AUDIT_DIR/day41-running-release.json" \
                      "$AUDIT_DIR/day41-backend-container-inspect.json" \
                      "$AUDIT_DIR/day41-frontend-container-inspect.json" \
                      "$AUDIT_DIR/day41-evidence-summary.txt" \
                      > "$CHECKSUM_FILE"

                    cat "$CHECKSUM_FILE"

                    tar -czf "$EVIDENCE_BUNDLE" \
                      "$AUDIT_JSON" \
                      "$AUDIT_TEXT" \
                      "$CHECKSUM_FILE" \
                      "$AUDIT_DIR/day41-running-release.json" \
                      "$AUDIT_DIR/day41-backend-container-inspect.json" \
                      "$AUDIT_DIR/day41-frontend-container-inspect.json" \
                      "$AUDIT_DIR/day41-evidence-summary.txt"

                    echo "Day 41 evidence bundle listing:"
                    tar -tzf "$EVIDENCE_BUNDLE"

                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day41-deployment-audit.json"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day41-deployment-audit.txt"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day41-evidence-checksums.txt"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day41-running-release.json"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day41-evidence-summary.txt"

                    sha256sum -c "$CHECKSUM_FILE"

                    echo "Day 41 evidence bundle created and checksums verified."
                    '''
                }
            }
        }

        stage('Update Day 41 Audit Report With Artifact Evidence') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    BUNDLE_SHA=$(sha256sum "$EVIDENCE_BUNDLE" | awk '{print $1}')
                    CHECKSUM_SHA=$(sha256sum "$CHECKSUM_FILE" | awk '{print $1}')

                    cat >> "$AUDIT_TEXT" <<EOF

Artifact packaging:
- Evidence bundle: $EVIDENCE_BUNDLE
- Evidence bundle SHA256: $BUNDLE_SHA
- Checksum file: $CHECKSUM_FILE
- Checksum file SHA256: $CHECKSUM_SHA
- Jenkins archiveArtifacts: enabled
EOF

                    grep "$BUNDLE_SHA" "$AUDIT_TEXT"
                    grep "$CHECKSUM_SHA" "$AUDIT_TEXT"

                    echo "Day 41 audit report updated with artifact evidence."
                    '''
                }
            }
        }

        stage('Archive Day 41 Evidence Artifacts') {
            steps {
                dir("${PROJECT_DIR}") {
                    archiveArtifacts artifacts: 'deployment-audit/day41-*', fingerprint: true
                }
            }
        }

        stage('Show Day 41 Deployment Diagnostics') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "Day 41 selected DEPLOY_ENV: $DEPLOY_ENV"
                    echo "Day 41 base env file: $BASE_ENV_FILE"
                    echo "Day 41 runtime env file: $RUNTIME_ENV_FILE"
                    echo "Day 41 expected image tag: $EXPECTED_IMAGE_TAG"

                    echo "Day 41 audit files:"
                    ls -la "$AUDIT_DIR"

                    echo "Day 41 evidence checksums:"
                    cat "$CHECKSUM_FILE"

                    echo "Day 41 evidence bundle:"
                    ls -lh "$EVIDENCE_BUNDLE"

                    echo "Day 41 Docker Compose service status:"
                    docker compose --env-file "$RUNTIME_ENV_FILE" ps

                    echo "Day 41 containers:"
                    docker ps -a --filter "name=day41_"

                    echo "Day 41 backend image:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true

                    echo "Day 41 frontend image:"
                    docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}' || true

                    echo "Day 41 backend release manifest:"
                    docker exec "$BACKEND_CONTAINER" cat /app/release.json || true

                    echo "Day 41 backend health status:"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                    echo "Recent Day 41 backend logs:"
                    docker logs --tail=120 "$BACKEND_CONTAINER" || true

                    echo "Recent Day 41 frontend logs:"
                    docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Day 41 pipeline completed successfully. Evidence bundle was packaged and archived.'
        }

        failure {
            echo 'Day 41 pipeline failed. Collecting failure diagnostics...'
        }

        always {
            dir("${PROJECT_DIR}") {
                sh '''
                echo "Final Day 41 selected DEPLOY_ENV:"
                echo "$DEPLOY_ENV"

                echo "Final Day 41 runtime env file:"
                echo "$RUNTIME_ENV_FILE"

                echo "Final Day 41 audit files:"
                ls -la "$AUDIT_DIR" || true

                echo "Final Day 41 evidence bundle listing:"
                tar -tzf "$EVIDENCE_BUNDLE" || true

                echo "Final Day 41 Docker Compose status:"
                docker compose --env-file "$RUNTIME_ENV_FILE" ps || true

                echo "Final Day 41 container list:"
                docker ps -a --filter "name=day41_" || true

                echo "Final Day 41 backend image:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true

                echo "Final Day 41 frontend image:"
                docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}' || true

                echo "Final Day 41 backend release manifest:"
                docker exec "$BACKEND_CONTAINER" cat /app/release.json || true

                echo "Final Day 41 backend health:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}' || true

                echo "Final Day 41 backend logs:"
                docker logs --tail=120 "$BACKEND_CONTAINER" || true

                echo "Final Day 41 frontend logs:"
                docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                '''
            }
        }
    }
}
