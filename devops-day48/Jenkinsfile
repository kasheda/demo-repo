                set -e

                API_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-api-smoke' http://127.0.0.1:3000/api/message")
                METRICS_RESPONSE=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-metrics-smoke' http://127.0.0.1:3000/metrics")
                PAGE_RESPONSE=$(docker exec "$FRONTEND_CONTAINER" sh -c "wget -qO- http://127.0.0.1/")

                echo "$API_RESPONSE"
                echo "$METRICS_RESPONSE"
                echo "$PAGE_RESPONSE"

                echo "$API_RESPONSE" | grep 'Hello from Day 48 backend API'
                echo "$METRICS_RESPONSE" | grep '"metricsEnabled":true'
                echo "$METRICS_RESPONSE" | grep '"/api/deployment-window"'
                echo "$PAGE_RESPONSE" | grep 'DevOps Day 48'
                echo "$PAGE_RESPONSE" | grep 'deployment window and freeze gate'
                '''
            }
        }

        stage('Verify Day 48 Backend Logs') {
            steps {
                sh '''
                set -e

                LOGS=$(docker logs "$BACKEND_CONTAINER" 2>&1)

                echo "$LOGS" | grep 'request_completed'
                echo "$LOGS" | grep 'day48-api-smoke'
                echo "$LOGS" | grep 'day48-final-config'
                echo "$LOGS" | grep 'day48-final-deployment-window'
                echo "$LOGS" | grep "$EXPECTED_CHANGE_RECORD_ID"
                echo "$LOGS" | grep "$EXPECTED_DEPLOYMENT_WINDOW_STATUS"
                '''
            }
        }

        stage('Write Day 48 Deployment Audit Report') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    mkdir -p "$AUDIT_DIR"

                    AUDIT_CREATED_AT=$(date -u +%Y-%m-%dT%H-%M-%SZ)
                    BACKEND_IMAGE=$(docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}')
                    FRONTEND_IMAGE=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.Config.Image}}')
                    BACKEND_HEALTH=$(docker inspect "$BACKEND_CONTAINER" --format='{{.State.Health.Status}}')
                    FRONTEND_RUNNING=$(docker inspect "$FRONTEND_CONTAINER" --format='{{.State.Running}}')
                    PROMOTION_PERFORMED=$(grep DAY48_PROMOTION_PERFORMED ../day48-promotion-result.env | cut -d '=' -f 2)

                    FINAL_CONFIG=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-audit-config' http://127.0.0.1:3000/api/config")
                    FINAL_CHANGE_RECORD=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-audit-change-record' http://127.0.0.1:3000/api/change-record")
                    FINAL_APPROVAL=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-audit-approval-record' http://127.0.0.1:3000/api/approval-record")
                    FINAL_WINDOW=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-audit-deployment-window' http://127.0.0.1:3000/api/deployment-window")

                    if [ "$PROMOTION_PERFORMED" = "true" ]; then
                      FINAL_IMAGE_TAG="$EXPECTED_PRODLIKE_IMAGE_TAG"
                      FINAL_DEPLOY_TARGET="prodlike"
                    else
                      FINAL_IMAGE_TAG="$EXPECTED_STAGING_IMAGE_TAG"
                      FINAL_DEPLOY_TARGET="staging"
                    fi

                    cat > "$AUDIT_JSON" <<EOF
{
  "day": "Day 48",
  "auditCreatedAt": "$AUDIT_CREATED_AT",
  "jenkinsBuildNumber": "$EXPECTED_BUILD_NUMBER",
  "promoteToProdlike": "$PROMOTE_TO_PRODLIKE",
  "forceStagingStabilityFailure": "$FORCE_STAGING_STABILITY_FAILURE",
  "skipReleaseNotes": "$SKIP_RELEASE_NOTES",
  "promotionPerformed": $PROMOTION_PERFORMED,
  "changeRecordId": "$EXPECTED_CHANGE_RECORD_ID",
  "releaseNotesStatus": "$EXPECTED_RELEASE_NOTES_STATUS",
  "approvalStatus": "$EXPECTED_APPROVAL_STATUS",
  "approvedBy": "$EXPECTED_APPROVED_BY",
  "approvalReason": "$EXPECTED_APPROVAL_REASON",
  "deploymentWindowStatus": "$EXPECTED_DEPLOYMENT_WINDOW_STATUS",
  "changeFreezeActive": "$EXPECTED_CHANGE_FREEZE_ACTIVE",
  "freezeReason": "$EXPECTED_FREEZE_REASON",
  "releaseNotesFile": "$RELEASE_NOTES_MD",
  "changeRecordFile": "$CHANGE_RECORD_JSON",
  "approvalRecordFile": "$APPROVAL_RECORD_JSON",
  "deploymentWindowFile": "$DEPLOYMENT_WINDOW_JSON",
  "expected": {
    "stagingImageTag": "$EXPECTED_STAGING_IMAGE_TAG",
    "prodlikeImageTag": "$EXPECTED_PRODLIKE_IMAGE_TAG",
    "rollbackImageTag": "$EXPECTED_ROLLBACK_IMAGE_TAG",
    "finalImageTag": "$FINAL_IMAGE_TAG",
    "finalDeployTarget": "$FINAL_DEPLOY_TARGET",
    "gitCommit": "$EXPECTED_GIT_COMMIT",
    "releaseCreatedAt": "$EXPECTED_RELEASE_CREATED_AT"
  },
  "containers": {
    "backendContainer": "$BACKEND_CONTAINER",
    "frontendContainer": "$FRONTEND_CONTAINER",
    "backendImage": "$BACKEND_IMAGE",
    "frontendImage": "$FRONTEND_IMAGE",
    "backendHealth": "$BACKEND_HEALTH",
    "frontendRunning": "$FRONTEND_RUNNING"
  },
  "verification": {
    "releaseNotesGenerated": true,
    "changeRecordGenerated": true,
    "approvalRecordGenerated": true,
    "deploymentWindowRecordGenerated": true,
    "approvalGateEvaluated": true,
    "deploymentWindowGateEvaluated": true,
    "stagingBuilt": true,
    "prodlikeBuilt": true,
    "stagingMonitoringPassed": true,
    "promotionGateEvaluated": true,
    "promotionPerformed": $PROMOTION_PERFORMED,
    "finalDeploymentHealthy": true,
    "releaseManifestMatchesRuntime": true,
    "metricsPassed": true,
    "logsPassed": true
  }
}
EOF

                    cat > "$AUDIT_TEXT" <<EOF
Day 48 Deployment Audit Report
==============================

Audit created at: $AUDIT_CREATED_AT
Jenkins build number: $EXPECTED_BUILD_NUMBER

Promote to prodlike: $PROMOTE_TO_PRODLIKE
Force staging stability failure: $FORCE_STAGING_STABILITY_FAILURE
Skip release notes: $SKIP_RELEASE_NOTES
Promotion performed: $PROMOTION_PERFORMED

Change record ID: $EXPECTED_CHANGE_RECORD_ID
Release notes status: $EXPECTED_RELEASE_NOTES_STATUS
Approval status: $EXPECTED_APPROVAL_STATUS
Approved by: $EXPECTED_APPROVED_BY
Approval reason: $EXPECTED_APPROVAL_REASON
Deployment window status: $EXPECTED_DEPLOYMENT_WINDOW_STATUS
Change freeze active: $EXPECTED_CHANGE_FREEZE_ACTIVE
Freeze reason: $EXPECTED_FREEZE_REASON

Release notes file: $RELEASE_NOTES_MD
Change record file: $CHANGE_RECORD_JSON
Approval record file: $APPROVAL_RECORD_JSON
Deployment window file: $DEPLOYMENT_WINDOW_JSON

Staging image tag: $EXPECTED_STAGING_IMAGE_TAG
Prodlike image tag: $EXPECTED_PRODLIKE_IMAGE_TAG
Rollback image tag: $EXPECTED_ROLLBACK_IMAGE_TAG
Final image tag: $FINAL_IMAGE_TAG
Final deploy target: $FINAL_DEPLOY_TARGET

Backend image: $BACKEND_IMAGE
Frontend image: $FRONTEND_IMAGE
Backend health: $BACKEND_HEALTH
Frontend running: $FRONTEND_RUNNING

Final config response:
$FINAL_CONFIG

Final change record response:
$FINAL_CHANGE_RECORD

Final approval response:
$FINAL_APPROVAL

Final deployment window response:
$FINAL_WINDOW
EOF

                    cp ../day48-staging-stability-checks.log "$AUDIT_DIR/day48-staging-stability-checks.log" 2>/dev/null || true

                    grep "\\"day\\": \\"Day 48\\"" "$AUDIT_JSON"
                    grep "\\"deploymentWindowRecordGenerated\\": true" "$AUDIT_JSON"
                    grep "\\"deploymentWindowGateEvaluated\\": true" "$AUDIT_JSON"
                    grep "\\"deploymentWindowStatus\\": \\"$EXPECTED_DEPLOYMENT_WINDOW_STATUS\\"" "$AUDIT_JSON"
                    grep "\\"backendHealth\\": \\"healthy\\"" "$AUDIT_JSON"
                    grep "\\"releaseManifestMatchesRuntime\\": true" "$AUDIT_JSON"

                    grep "Day 48 Deployment Audit Report" "$AUDIT_TEXT"
                    grep "$EXPECTED_CHANGE_RECORD_ID" "$AUDIT_TEXT"
                    grep "$EXPECTED_DEPLOYMENT_WINDOW_STATUS" "$AUDIT_TEXT"
                    '''
                }
            }
        }

        stage('Package Day 48 Evidence Bundle') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    docker exec "$BACKEND_CONTAINER" cat /app/release.json > "$AUDIT_DIR/day48-running-release.json"
                    docker inspect "$BACKEND_CONTAINER" > "$AUDIT_DIR/day48-backend-container-inspect.json"
                    docker inspect "$FRONTEND_CONTAINER" > "$AUDIT_DIR/day48-frontend-container-inspect.json"

                    {
                      echo "Day 48 Evidence Bundle Contents"
                      echo "==============================="
                      echo "Promote to prodlike: $PROMOTE_TO_PRODLIKE"
                      echo "Force staging stability failure: $FORCE_STAGING_STABILITY_FAILURE"
                      echo "Skip release notes: $SKIP_RELEASE_NOTES"
                      echo "Change record ID: $EXPECTED_CHANGE_RECORD_ID"
                      echo "Approval status: $EXPECTED_APPROVAL_STATUS"
                      echo "Approved by: $EXPECTED_APPROVED_BY"
                      echo "Deployment window status: $EXPECTED_DEPLOYMENT_WINDOW_STATUS"
                      echo "Change freeze active: $EXPECTED_CHANGE_FREEZE_ACTIVE"
                      echo "Freeze reason: $EXPECTED_FREEZE_REASON"
                      echo "Staging image tag: $EXPECTED_STAGING_IMAGE_TAG"
                      echo "Prodlike image tag: $EXPECTED_PRODLIKE_IMAGE_TAG"
                      echo "Rollback image tag: $EXPECTED_ROLLBACK_IMAGE_TAG"
                      echo ""
                      echo "Included files:"
                      find "$AUDIT_DIR" "$RELEASE_NOTES_DIR" -maxdepth 1 -type f | sort
                    } > "$AUDIT_DIR/day48-evidence-summary.txt"

                    sha256sum \
                      "$AUDIT_JSON" \
                      "$AUDIT_TEXT" \
                      "$AUDIT_DIR/day48-running-release.json" \
                      "$AUDIT_DIR/day48-backend-container-inspect.json" \
                      "$AUDIT_DIR/day48-frontend-container-inspect.json" \
                      "$AUDIT_DIR/day48-evidence-summary.txt" \
                      "$RELEASE_NOTES_MD" \
                      "$CHANGE_RECORD_JSON" \
                      "$APPROVAL_RECORD_JSON" \
                      "$DEPLOYMENT_WINDOW_JSON" \
                      > "$CHECKSUM_FILE"

                    tar -czf "$EVIDENCE_BUNDLE" \
                      "$AUDIT_JSON" \
                      "$AUDIT_TEXT" \
                      "$CHECKSUM_FILE" \
                      "$AUDIT_DIR/day48-running-release.json" \
                      "$AUDIT_DIR/day48-backend-container-inspect.json" \
                      "$AUDIT_DIR/day48-frontend-container-inspect.json" \
                      "$AUDIT_DIR/day48-evidence-summary.txt" \
                      "$RELEASE_NOTES_MD" \
                      "$CHANGE_RECORD_JSON" \
                      "$APPROVAL_RECORD_JSON" \
                      "$DEPLOYMENT_WINDOW_JSON"

                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day48-deployment-audit.json"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day48-deployment-audit.txt"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day48-evidence-checksums.txt"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day48-release-notes.md"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day48-change-record.json"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day48-approval-record.json"
                    tar -tzf "$EVIDENCE_BUNDLE" | grep "day48-deployment-window-record.json"

                    sha256sum -c "$CHECKSUM_FILE"
                    '''
                }
            }
        }

        stage('Archive Day 48 Evidence Artifacts') {
            steps {
                dir("${PROJECT_DIR}") {
                    archiveArtifacts artifacts: 'deployment-audit/day48-*,release-notes/day48-*', fingerprint: true
                }
            }
        }

        stage('Show Day 48 Deployment Diagnostics') {
            steps {
                dir("${PROJECT_DIR}") {
                    sh '''
                    set -e

                    echo "PROMOTE_TO_PRODLIKE=$PROMOTE_TO_PRODLIKE"
                    echo "FORCE_STAGING_STABILITY_FAILURE=$FORCE_STAGING_STABILITY_FAILURE"
                    echo "SKIP_RELEASE_NOTES=$SKIP_RELEASE_NOTES"
                    echo "APPROVAL_STATUS=$APPROVAL_STATUS"
                    echo "APPROVED_BY=$APPROVED_BY"
                    echo "DEPLOYMENT_WINDOW_STATUS=$DEPLOYMENT_WINDOW_STATUS"
                    echo "CHANGE_FREEZE_ACTIVE=$CHANGE_FREEZE_ACTIVE"
                    echo "FREEZE_REASON=$FREEZE_REASON"
                    echo "EXPECTED_CHANGE_RECORD_ID=$EXPECTED_CHANGE_RECORD_ID"

                    ls -la "$AUDIT_DIR"
                    ls -la "$RELEASE_NOTES_DIR"

                    docker ps -a --filter "name=day48_"
                    docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true
                    docker exec "$BACKEND_CONTAINER" cat /app/release.json || true
                    docker logs --tail=120 "$BACKEND_CONTAINER" || true
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Day 48 pipeline completed successfully. Deployment window and freeze gate verified.'
        }

        failure {
            echo 'Day 48 pipeline failed. Collecting failure diagnostics...'
        }

        always {
            dir("${PROJECT_DIR}") {
                sh '''
                echo "Final Day 48 audit files:"
                ls -la "$AUDIT_DIR" || true

                echo "Final Day 48 release notes files:"
                ls -la "$RELEASE_NOTES_DIR" || true

                echo "Final Day 48 evidence bundle listing:"
                tar -tzf "$EVIDENCE_BUNDLE" || true

                echo "Final Day 48 container list:"
                docker ps -a --filter "name=day48_" || true

                echo "Final Day 48 backend image:"
                docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}' || true

                echo "Final Day 48 backend release manifest:"
                docker exec "$BACKEND_CONTAINER" cat /app/release.json || true

                echo "Final Day 48 backend logs:"
                docker logs --tail=120 "$BACKEND_CONTAINER" || true

                echo "Final Day 48 frontend logs:"
                docker logs --tail=50 "$FRONTEND_CONTAINER" || true
                '''
            }
        }
    }
}
