                '''
            }
        }

        stage('Verify Day 48 Final Deployment State') {
            steps {
                sh '''
                set -e

                PROMOTION_PERFORMED=$(grep DAY48_PROMOTION_PERFORMED day48-promotion-result.env | cut -d '=' -f 2)

                FINAL_CONFIG=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-final-config' http://127.0.0.1:3000/api/config")
                FINAL_CHANGE_RECORD=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-final-change-record' http://127.0.0.1:3000/api/change-record")
                FINAL_APPROVAL=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-final-approval-record' http://127.0.0.1:3000/api/approval-record")
                FINAL_WINDOW=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-final-deployment-window' http://127.0.0.1:3000/api/deployment-window")
                FINAL_STABILITY=$(docker exec "$BACKEND_CONTAINER" sh -c "wget -qO- --header='X-Request-Id: day48-final-stability' http://127.0.0.1:3000/api/stability")
                FINAL_IMAGE=$(docker inspect "$BACKEND_CONTAINER" --format='{{.Config.Image}}')

                echo "$FINAL_CONFIG"
                echo "$FINAL_CHANGE_RECORD"
                echo "$FINAL_APPROVAL"
                echo "$FINAL_WINDOW"
                echo "$FINAL_STABILITY"
                echo "$FINAL_IMAGE"

                if [ "$PROMOTION_PERFORMED" = "true" ]; then
                  echo "$FINAL_CONFIG" | grep '"environment":"day48-prodlike-env"'
                  echo "$FINAL_CONFIG" | grep '"deployTarget":"prodlike"'
                  echo "$FINAL_CONFIG" | grep "\\"imageTag\\":\\"$EXPECTED_PRODLIKE_IMAGE_TAG\\""
                  echo "$FINAL_IMAGE" | grep "day48-backend:$EXPECTED_PRODLIKE_IMAGE_TAG"
                else
                  echo "$FINAL_CONFIG" | grep '"environment":"day48-staging-env"'
                  echo "$FINAL_CONFIG" | grep '"deployTarget":"staging"'
                  echo "$FINAL_CONFIG" | grep "\\"imageTag\\":\\"$EXPECTED_STAGING_IMAGE_TAG\\""
                  echo "$FINAL_IMAGE" | grep "day48-backend:$EXPECTED_STAGING_IMAGE_TAG"
                fi

                echo "$FINAL_CHANGE_RECORD" | grep "\\"changeRecordId\\":\\"$EXPECTED_CHANGE_RECORD_ID\\""
                echo "$FINAL_CHANGE_RECORD" | grep '"releaseNotesStatus":"generated"'
                echo "$FINAL_APPROVAL" | grep "\\"approvalStatus\\":\\"$EXPECTED_APPROVAL_STATUS\\""
                echo "$FINAL_APPROVAL" | grep "\\"approvedBy\\":\\"$EXPECTED_APPROVED_BY\\""
                echo "$FINAL_WINDOW" | grep "\\"deploymentWindowStatus\\":\\"$EXPECTED_DEPLOYMENT_WINDOW_STATUS\\""
                echo "$FINAL_STABILITY" | grep '"stable":true'
                echo "$FINAL_STABILITY" | grep '"releaseManifestMatchesRuntime":true'
                '''
            }
        }

        stage('Smoke Test Day 48 API Metrics Frontend') {
            steps {
